# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
APP_PORT=3000
APP_PREFIX=api/v1

# =============================================================================
# DATABASE — PostgreSQL
# =============================================================================
# Full DSN used by Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/kpnhcis?schema=public"

# Individual fields (used by health checks / direct pg clients if needed)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kpnhcis
DB_USER=postgres
DB_PASSWORD=secret

# =============================================================================
# JWT
# =============================================================================
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_32_CHARS_MIN
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_32_CHARS_MIN
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# REDIS — Shared by Cache, BullMQ, and Socket.IO adapter
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Full URL form (used by cache-manager-redis-yet)
REDIS_URL=redis://:PASSWORD@localhost:6379/0

# =============================================================================
# BULLMQ — Queue names (consumers reference these)
# =============================================================================
BULL_QUEUE_PAYROLL=payroll
BULL_QUEUE_ATTENDANCE=attendance
BULL_QUEUE_NOTIFICATION=notification

# =============================================================================
# SOCKET.IO
# =============================================================================
SOCKET_CORS_ORIGIN=http://localhost:9000

# =============================================================================
# THROTTLE (rate limiting)
# =============================================================================
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# =============================================================================
# STORAGE (for future file upload support)
# =============================================================================
STORAGE_DRIVER=local
STORAGE_LOCAL_BASE_PATH=./storage
# S3 — only required when STORAGE_DRIVER=s3
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
