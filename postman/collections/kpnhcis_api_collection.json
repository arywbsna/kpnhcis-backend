        {
          "name": "Deactivate Unit (Soft Delete)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/organization/units/:id/deactivate",
              "host": ["{{baseUrl}}"],
              "path": ["organization", "units", ":id", "deactivate"],
              "variable": [
                {
