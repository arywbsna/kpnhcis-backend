{
  "info": {
    "_postman_id": "c4f3b2a1-d5e6-7890-f1a2-b3c4d5e6f7a8",
    "name": "KPN-HCIS Enterprise API",
    "description": "Comprehensive API test collection for KPN-HCIS Backend.\n\nPhases covered:\n  Phase 1 — Auth (JWT access + refresh token pair)\n  Phase 2 — RBAC (CASL PermissionsGuard + CheckPermissions)\n  Phase 3 — Organization Units (Adjacency List + recursive CTE tree)\n  Phase 4 — Leave Request Lifecycle (XState v5 state machine)\n  Phase 5 — AI Analytics (Qwen/DashScope BI layer)\n\nWorkflow: Run \"Login\" first — the test script auto-populates {{jwtToken}} and {{refreshToken}} for all subsequent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "🔑 Authentication",
      "description": "Public login and token management endpoints. Run Login first — the test script saves accessToken → {{jwtToken}} and refreshToken → {{refreshToken}} automatically.",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200 OK\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has accessToken — saved to {{jwtToken}}\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"accessToken\");",
                  "    pm.expect(json.accessToken).to.be.a(\"string\");",
                  "    pm.environment.set(\"jwtToken\", json.accessToken);",
                  "    console.log(\"\\u2705 jwtToken saved to environment\");",
                  "});",
                  "",
                  "pm.test(\"Response has refreshToken — saved to {{refreshToken}}\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"refreshToken\");",
                  "    pm.expect(json.refreshToken).to.be.a(\"string\");",
                  "    pm.environment.set(\"refreshToken\", json.refreshToken);",
                  "    console.log(\"\\u2705 refreshToken saved to environment\");",
                  "});",
                  "",
                  "pm.test(\"Response has expiresIn (seconds)\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"expiresIn\");",
                  "    pm.expect(json.expiresIn).to.be.a(\"number\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"staff@corespace.com\",\n  \"password\": \"password\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Authenticate with email and password. Returns accessToken (15 min), refreshToken (7 days), and expiresIn (seconds). The test script auto-saves both tokens to the active environment."
          },
          "response": []
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{refreshToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "none"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "Exchange a valid refresh token for a new access + refresh token pair. Send the refresh token in the Authorization: Bearer header (pre-configured via {{refreshToken}}). Returns 200 OK with a new AuthTokensDto."
          },
          "response": []
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "none"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Invalidates the current session by clearing the stored refreshTokenHash on the user record. Returns 204 No Content. Subsequent refresh attempts will fail with 401."
          },
          "response": []
        }
      ]
    },
    {
      "name": "👤 Users Management",
      "description": "Full CRUD for user accounts. All routes require JWT. Permissions enforced by CASL PermissionsGuard: create/read/update/delete on subject 'User'.",
      "item": [
        {
          "name": "Create User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response contains id — saved to {{userId}}\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"id\");",
                  "    pm.environment.set(\"userId\", json.id);",
                  "    console.log(\"\\u2705 userId saved:\", json.id);",
                  "});",
                  "",
                  "pm.test(\"Sensitive fields are not exposed\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.not.have.property(\"passwordHash\");",
                  "    pm.expect(json).to.not.have.property(\"refreshTokenHash\");",
                  "});"
                ]
              }
            }
          ],
