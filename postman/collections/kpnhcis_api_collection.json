            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"{{employeeId}}\",\n  \"email\": \"john.doe@kpn.id\",\n  \"password\": \"Password123!\",\n  \"fullName\": \"John Doe\",\n  \"unitId\": \"{{testUnitId}}\",\n  \"roleIds\": []\n}",
