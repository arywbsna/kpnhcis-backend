      ]
    },
    {
      "name": "📝 Leave Management (XState Engine)",
      "description": "Full leave request lifecycle powered by XState v5. State machine: DRAFT → PENDING_APPROVAL → APPROVED_BY_SUPERVISOR → APPROVED / REJECTED / CANCELLED.\n\nWorkflow: Create (DRAFT) → Submit → Approve (supervisor) → Approve (HRD final) or Reject/Cancel at any non-terminal state.",
      "item": [
        {
          "name": "Create Leave Request (DRAFT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Initial status is DRAFT\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.status).to.equal(\"DRAFT\");",
                  "});",
                  "",
                  "pm.test(\"Response contains id — saved to {{leaveRequestId}}\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"id\");",
                  "    pm.environment.set(\"leaveRequestId\", json.id);",
                  "    console.log(\"\\u2705 leaveRequestId saved:\", json.id);",
                  "});",
                  "",
                  "pm.test(\"XState context is seeded in payload\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"payload\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leaveType\": \"ANNUAL\",\n  \"startDate\": \"2026-06-01\",\n  \"endDate\": \"2026-06-05\",\n  \"totalDays\": 5,\n  \"reason\": \"Annual family vacation\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/leave-requests",
              "host": ["{{baseUrl}}"],
              "path": ["leave-requests"]
            },
            "description": "Creates a new leave request in DRAFT state for the authenticated user. leaveType enum: ANNUAL | SICK | MATERNITY | PATERNITY | SPECIAL | UNPAID. totalDays min: 0.5, max: 365 (step 0.5). The XState context snapshot is seeded into the payload JSONB column."
          },
          "response": []
        },
        {
          "name": "List Leave Requests",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leave-requests?skip=0&take=20",
              "host": ["{{baseUrl}}"],
              "path": ["leave-requests"],
              "query": [
                {
                  "key": "skip",
                  "value": "0",
                  "description": "Pagination offset"
                },
                {
                  "key": "take",
                  "value": "20",
                  "description": "Page size"
                },
                {
                  "key": "status",
                  "value": "PENDING_APPROVAL",
                  "description": "Filter by LeaveRequestStatus enum value",
                  "disabled": true
                },
                {
                  "key": "leaveType",
                  "value": "ANNUAL",
                  "description": "Filter by LeaveType enum value",
                  "disabled": true
                },
                {
                  "key": "startDateFrom",
                  "value": "2026-01-01",
                  "description": "ISO 8601 date — filter startDate >= this value",
                  "disabled": true
                },
                {
                  "key": "startDateTo",
                  "value": "2026-12-31",
                  "description": "ISO 8601 date — filter startDate <= this value",
                  "disabled": true
                },
                {
                  "key": "userId",
                  "value": "{{userId}}",
                  "description": "Approvers only — query another user's requests",
                  "disabled": true
                }
              ]
            },
            "description": "Paginated list with optional filters. Regular employees always see only their own requests (userId is overridden to request.user.id). Approvers/HRD can pass ?userId= to query other employees within their CASL-scoped unit."
          },
          "response": []
        },
        {
          "name": "Get Leave Request by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leave-requests/:id",
              "host": ["{{baseUrl}}"],
              "path": ["leave-requests", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{leaveRequestId}}",
                  "description": "Leave Request UUID — auto-populated by Create test script"
                }
              ]
            },
            "description": "Returns the full leave request with all LeaveApproval audit rows included (ordered by decidedAt ASC). Throws 404 if not found."
          },
          "response": []
        },
        {
          "name": "Get Available Transitions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/leave-requests/:id/transitions",
              "host": ["{{baseUrl}}"],
              "path": ["leave-requests", ":id", "transitions"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{leaveRequestId}}",
                  "description": "Leave Request UUID"
                }
              ]
            },
            "description": "Returns { status: LeaveRequestStatus, allowedEvents: string[] } for the current XState state node. The Vue 3 / Quasar frontend uses this response to conditionally render action buttons — only reachable transitions are shown. Example: { status: 'PENDING_APPROVAL', allowedEvents: ['APPROVE_BY_SUPERVISOR', 'REJECT', 'CANCEL'] }"
          },
          "response": []
        },
        {
          "name": "Submit Leave Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"approverIds\": []\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/leave-requests/:id/submit",
              "host": ["{{baseUrl}}"],
              "path": ["leave-requests", ":id", "submit"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{leaveRequestId}}",
                  "description": "Leave Request UUID"
                }
              ]
            },
            "description": "XState event: SUBMIT. Transitions DRAFT → PENDING_APPROVAL. Optional approverIds (UUID array) pre-designates which approvers are authorized. Returns 200 OK with the updated leave request."
          },
          "response": []
        },
        {
          "name": "Approve Leave Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"remarks\": \"Approved — no conflicting schedules found.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/leave-requests/:id/approve",
              "host": ["{{baseUrl}}"],
              "path": ["leave-requests", ":id", "approve"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{leaveRequestId}}",
                  "description": "Leave Request UUID"
                }
              ]
            },
            "description": "Smart approval — auto-routes to the correct XState event based on current status:\n  PENDING_APPROVAL       → APPROVE_BY_SUPERVISOR (supervisor step)\n  APPROVED_BY_SUPERVISOR → APPROVE (HRD final step)\n  Any other status       → 409 ConflictException\n\nThe authenticated user's ID is implicitly used as approverId — approvers never pass their own ID, preventing impersonation. Returns 200 OK."
          },
          "response": []
        },
        {
          "name": "Reject Leave Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"remarks\": \"Rejected — critical project milestone during the requested period.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/leave-requests/:id/reject",
              "host": ["{{baseUrl}}"],
              "path": ["leave-requests", ":id", "reject"],
              "variable": [
                {
                  "key": "id",
                  "value": "{{leaveRequestId}}",
                  "description": "Leave Request UUID"
                }
              ]
            },
