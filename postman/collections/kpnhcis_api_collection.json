      ]
    },
    {
      "name": "🏢 Organization Units",
      "description": "Organizational unit hierarchy management. Uses PostgreSQL recursive CTEs for tree traversal and ancestor chain resolution. All routes require 'read Unit' permission minimum.",
      "item": [
        {
          "name": "Get Unit Tree",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/organization/units/tree",
              "host": ["{{baseUrl}}"],
              "path": ["organization", "units", "tree"],
              "query": [
                {
                  "key": "includeInactive",
                  "value": "false",
                  "description": "Set true to include soft-deactivated units",
                  "disabled": true
                }
              ]
            },
            "description": "Returns the full org chart as a nested UnitTreeNode tree built via an O(n) in-memory Map from a single DB query. Each node contains: id, name, code, description, parentId, isActive, createdAt, updatedAt, children[]."
          },
          "response": []
        },
        {
          "name": "List Units (Flat)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/organization/units",
              "host": ["{{baseUrl}}"],
              "path": ["organization", "units"]
            },
            "description": "Flat alphabetical list of all active units. Suitable for dropdowns and search-ahead selects in the frontend."
          },
          "response": []
        },
        {
          "name": "Create Unit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 201 Created\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response contains unit id — saved to {{testUnitId}}\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property(\"id\");",
                  "    pm.environment.set(\"testUnitId\", json.id);",
                  "    console.log(\"\\u2705 testUnitId updated:\", json.id);",
                  "});",
                  "",
                  "pm.test(\"Unit code matches uppercase pattern\", function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.code).to.match(/^[A-Z0-9_-]+$/);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Information Technology\",\n  \"code\": \"IT-DIV\",\n  \"description\": \"IT Division — manages all technology infrastructure\",\n  \"isActive\": true\n}",
