              "// ── system_leaves_list ────────────────────────────────────────────────────────",
              "pm.test('system_leaves_list maps same hex keys to display name strings', () => {",
              "  pm.expect(body.data.system_leaves_list).to.be.an('object');",
              "  Object.values(body.data.system_leaves_list).forEach(name => {",
              "    pm.expect(name).to.be.a('string').and.to.have.lengthOf.at.least(1);",
              "  });",
              "});",
              "",
              "// ── leave_recipients ──────────────────────────────────────────────────────────",
              "pm.test('leave_recipients is an array', () => {",
              "  pm.expect(body.data.leave_recipients).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
