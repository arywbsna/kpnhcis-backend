    {
      "name": "05 · getUpcomingTimeOff (Chronological Timeline Feed)",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "test-get-upcoming-timeoff",
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('Envelope: status === 1', () => {",
              "  pm.expect(body.status).to.eql(1);",
              "});",
              "",
              "// ── data is a flat array ──────────────────────────────────────────────────────",
              "pm.test('data is an array', () => {",
              "  pm.expect(body.data).to.be.an('array');",
              "});",
              "",
              "// ── Each entry carries the 4-field DWUpcomingTimeOffEntry contract ──────────",
              "pm.test('Each upcoming entry has id, title, date, day, type', () => {",
              "  body.data.forEach((entry, i) => {",
              "    pm.expect(entry, `entry[${i}] missing fields`).to.include.all.keys([",
              "      'id', 'title', 'date', 'day', 'type'",
              "    ]);",
              "  });",
              "});",
              "",
              "pm.test('date is YYYY-MM-DD, day is full English weekday name', () => {",
              "  const DAYS = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];",
              "  body.data.forEach((entry, i) => {",
              "    pm.expect(entry.date, `entry[${i}].date`).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
              "    pm.expect(DAYS, `entry[${i}].day '${entry.day}' must be valid weekday`).to.include(entry.day);",
              "  });",
              "});",
              "",
              "pm.test('type is National Holiday or a leave display name string', () => {",
              "  body.data.forEach((entry, i) => {",
              "    pm.expect(entry.type, `entry[${i}].type`).to.be.a('string').and.to.have.lengthOf.at.least(1);",
              "  });",
              "});",
              "",
              "// ── Chronological order: dates must be non-decreasing ─────────────────────",
              "pm.test('Entries are sorted chronologically (non-decreasing dates)', () => {",
              "  for (let i = 1; i < body.data.length; i++) {",
              "    pm.expect(body.data[i].date >= body.data[i - 1].date,",
              "      `entry[${i}].date '${body.data[i].date}' must be >= entry[${i-1}].date '${body.data[i-1].date}'`",
              "    ).to.be.true;",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"{{targetEmployeeId}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/leaves/leavesApi/getUpcomingTimeOff",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "leaves", "leavesApi", "getUpcomingTimeOff"]
        },
        "description": "Chronological merged feed of upcoming national public holidays and approved personal leaves.  Default window: today → +90 days."
      },
      "response": []
    },

    {
      "name": "06 · getTeamStatus (Department Peer Visibility)",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "test-get-team-status",
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('Envelope: status === 1', () => {",
              "  pm.expect(body.status).to.eql(1);",
              "});",
              "",
              "// ── data is a Record<YYYY-MM-DD, DWTeamTimeOffBlock[]> ────────────────────────",
              "pm.test('data is a record object keyed by YYYY-MM-DD date strings', () => {",
              "  pm.expect(body.data).to.be.an('object');",
              "  Object.keys(body.data).forEach(key => {",
              "    pm.expect(key).to.match(/^\\d{4}-\\d{2}-\\d{2}$/, `key '${key}' must be YYYY-MM-DD`);",
              "  });",
              "});",
              "",
              "// ── Each day maps to an array of DWTeamTimeOffBlock items ─────────────────────",
              "pm.test('Each date entry maps to an array of DWTeamTimeOffBlock items', () => {",
              "  Object.entries(body.data).forEach(([date, blocks]) => {",
              "    pm.expect(blocks, `blocks for ${date}`).to.be.an('array');",
              "  });",
              "});",
              "",
              "pm.test('Each block carries type, title, users — or is an empty sentinel', () => {",
              "  Object.entries(body.data).forEach(([date, blocks]) => {",
              "    blocks.forEach((block, i) => {",
              "      pm.expect(block, `${date}[${i}] missing fields`).to.include.all.keys([",
              "        'type', 'title', 'users'",
              "      ]);",
              "      pm.expect(block.users, `${date}[${i}].users`).to.be.an('array');",
              "    });",
              "  });",
              "});",
              "",
              "pm.test('Each user snapshot in a non-empty block has required profile fields', () => {",
              "  Object.entries(body.data).forEach(([date, blocks]) => {",
              "    blocks.forEach((block, i) => {",
              "      if (block.users.length > 0) {",
              "        block.users.forEach((snap, j) => {",
              "          pm.expect(snap, `${date}[${i}].users[${j}]`).to.include.all.keys([",
              "            'employee_id', 'full_name', 'leave_type', 'start_date', 'end_date'",
              "          ]);",
              "        });",
              "      }",
              "    });",
              "  });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"start_date\": \"{{todayStr}}\",\n  \"end_date\":   \"{{endWindowStr}}\",\n  \"user_id\":    \"{{targetEmployeeId}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/leaves/leavesApi/getTeamStatus",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "leaves", "leavesApi", "getTeamStatus"]
