              "});",
              "",
              "// ── data.logs is a Record<YYYY-MM-DD, DWDayLogLedgerEntry> ───────────────────",
              "pm.test('data.logs is a record object keyed by YYYY-MM-DD', () => {",
              "  pm.expect(body.data.logs).to.be.an('object');",
              "  Object.keys(body.data.logs).forEach(key => {",
              "    pm.expect(key).to.match(/^\\d{4}-\\d{2}-\\d{2}$/, `log key '${key}' must be YYYY-MM-DD`);",
              "  });",
              "});",
              "",
              "// ── Full 36-field DWDayLogLedgerEntry contract on every entry ─────────────────",
              "pm.test('Each ledger entry carries all required DWDayLogLedgerEntry wire fields', () => {",
              "  const REQUIRED_FIELDS = [",
              "    'date', 'clock_in', 'clock_out',",
              "    'break_duration', 'paid_break', 'unpaid_break',",
              "    'final_work_duration', 'total_work_duration', 'short_leave_duration',",
              "    'overtime', 'late_mark', 'early_out',",
              "    'first_clockin', 'first_clockout',",
              "    'attendance_status', 'request_status',",
              "    'location', 'timesheet_status', 'timesheet_duration',",
              "    'actions', 'user_attendance_details',",
              "    'is_overnight', 'purpose',",
              "    'present_count', 'absent_count', 'leave_count', 'unpaid_count',",
              "    'request_id', 'log_id', 'is_policy_applicable',",
              "    'append_to_status', 'manager_comment', 'work_transfer_details',",
              "    'is_holiday', 'is_weekoff', 'is_leave'",
              "  ];",
              "  Object.entries(body.data.logs).forEach(([date, entry]) => {",
              "    pm.expect(entry, `entry for ${date}`).to.include.all.keys(REQUIRED_FIELDS);",
              "  });",
              "});",
              "",
              "// ── date in entry is DD-MM-YYYY (asymmetric inversion from outer YYYY-MM-DD key) ──",
              "pm.test('entry.date is DD-MM-YYYY (Darwinbox local display inversion)', () => {",
              "  Object.entries(body.data.logs).forEach(([isoKey, entry]) => {",
              "    pm.expect(entry.date).to.match(/^\\d{2}-\\d{2}-\\d{4}$/,",
              "      `entry.date '${entry.date}' must be DD-MM-YYYY`",
              "    );",
              "    // Verify the inversion is consistent with the outer YYYY-MM-DD key",
              "    const [y, m, d] = isoKey.split('-');",
              "    pm.expect(entry.date).to.eql(`${d}-${m}-${y}`);",
              "  });",
              "});",
              "",
              "// ── Window-level counters are stamped identically on all entries ─────────────",
              "pm.test('Window-level counters are identical across all ledger entries', () => {",
              "  const entries = Object.values(body.data.logs);",
              "  if (entries.length > 1) {",
              "    const ref = entries[0];",
              "    entries.forEach((entry, i) => {",
              "      pm.expect(entry.present_count, `entry[${i}].present_count`).to.eql(ref.present_count);",
              "      pm.expect(entry.absent_count,  `entry[${i}].absent_count`).to.eql(ref.absent_count);",
              "      pm.expect(entry.leave_count,   `entry[${i}].leave_count`).to.eql(ref.leave_count);",
              "      pm.expect(entry.unpaid_count,  `entry[${i}].unpaid_count`).to.eql(ref.unpaid_count);",
              "    });",
              "  }",
              "});",
              "",
              "// ── actions block ─────────────────────────────────────────────────────────────",
              "pm.test('actions block carries required 0|1 permission toggles', () => {",
              "  Object.entries(body.data.logs).forEach(([date, entry]) => {",
              "    const a = entry.actions;",
              "    pm.expect(a).to.include.all.keys([",
              "      'is_edit', 'is_delete', 'singleday_request',",
              "      'ot_journal_enable', 'att_register_enable', 'attendance_shift_change'",
              "    ]);",
              "    Object.values(a).forEach(v => pm.expect([0, 1]).to.include(v));",
              "  });",
              "});",
              "",
              "// ── request_status and work_transfer_details are always empty ─────────────────",
              "pm.test('request_status and work_transfer_details are always empty arrays', () => {",
              "  Object.entries(body.data.logs).forEach(([date, entry]) => {",
              "    pm.expect(entry.request_status,      `${date}.request_status`).to.eql([]);",
              "    pm.expect(entry.work_transfer_details, `${date}.work_transfer_details`).to.eql([]);",
              "  });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
