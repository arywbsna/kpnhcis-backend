{
  "info": {
    "_postman_id": "c7e2f841-3b09-4d5a-a8f2-91dc04e7b3a6",
    "name": "KPNHCIS — Time Management & Leaves (v1 Integration Suite)",
    "description": "Production-grade automated integration test collection for all 10 Time Management & Leaves endpoints.\n\n**Auth**: Collection-level Bearer token via {{jwtToken}}.\n**Dates**: Collection pre-request script injects {{todayStr}}, {{startWindowStr}}, {{endWindowStr}} as normalized UTC-midnight ISO dates — tests never rot.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },

  "event": [
    {
      "listen": "prerequest",
      "script": {
        "id": "coll-prereq-dates",
        "type": "text/javascript",
        "exec": [
          "// ─── Dynamic UTC-midnight date anchors ───────────────────────────────────────",
          "// Recalculated fresh on every collection run so date-range assertions",
          "// never drift against the live server timeline.",
          "",
          "const now   = new Date();",
          "const today = new Date(Date.UTC(",
          "  now.getUTCFullYear(),",
          "  now.getUTCMonth(),",
          "  now.getUTCDate()",
          "));",
          "",
          "const toISO = (d) => d.toISOString().slice(0, 10);",
          "",
          "const startWindow = new Date(today.getTime() - 14 * 86_400_000);",
          "const endWindow   = new Date(today.getTime() + 14 * 86_400_000);",
          "",
          "pm.collectionVariables.set('todayStr',       toISO(today));",
          "pm.collectionVariables.set('startWindowStr', toISO(startWindow));",
          "pm.collectionVariables.set('endWindowStr',   toISO(endWindow));"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "id": "coll-test-noop",
        "type": "text/javascript",
        "exec": [""]
      }
    }
  ],

  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "API host — override per environment (dev / staging / prod)"
    },
    {
      "key": "jwtToken",
      "value": "",
      "type": "string",
      "description": "JWT access token — populate via a login pre-run or environment override"
    },
    {
      "key": "targetEmployeeId",
      "value": "",
      "type": "string",
      "description": "Optional: Darwinbox source_employee_id, internal employeeId, or UUID for cross-user admin tests. Leave blank to default to the JWT principal."
    },
    {
      "key": "todayStr",
      "value": "",
      "type": "string",
      "description": "Injected by collection pre-request script — do not edit manually"
    },
    {
      "key": "startWindowStr",
      "value": "",
      "type": "string",
      "description": "Injected by collection pre-request script — do not edit manually"
    },
    {
      "key": "endWindowStr",
      "value": "",
      "type": "string",
      "description": "Injected by collection pre-request script — do not edit manually"
    }
  ],

  "item": [

    {
      "name": "01 · GetAttendanceDetails (Daily Timesheet Bootstrap)",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "test-get-attendance-details",
            "type": "text/javascript",
            "exec": [
              "// ── Envelope ─────────────────────────────────────────────────────────────────",
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('Envelope: status === 1', () => {",
              "  pm.expect(body.status).to.eql(1);",
              "});",
              "",
              "// ── data.columns ─────────────────────────────────────────────────────────────",
              "pm.test('data.columns is a non-empty array', () => {",
              "  pm.expect(body.data.columns).to.be.an('array').and.to.have.lengthOf.at.least(1);",
              "});",
              "",
              "pm.test('Each column entry carries key and title strings', () => {",
              "  body.data.columns.forEach(col => {",
              "    pm.expect(col.key).to.be.a('string');",
              "    pm.expect(col.title).to.be.a('string');",
              "  });",
              "});",
              "",
              "// ── data.shift ───────────────────────────────────────────────────────────────",
              "pm.test('data.shift carries required DWShiftDetails wire fields', () => {",
              "  const shift = body.data.shift;",
              "  pm.expect(shift).to.include.all.keys([",
              "    'id', 'shift_name', 'begin_time', 'end_time',",
              "    'begin_time_string', 'end_time_string', 'total_hours',",
              "    'is_overnight', 'is_null_shift'",
              "  ]);",
              "});",
              "",
              "pm.test('shift.is_overnight is 0|1 integer-boolean', () => {",
              "  pm.expect([0, 1]).to.include(body.data.shift.is_overnight);",
              "});",
              "",
              "pm.test('shift.is_null_shift is 0|1 integer-boolean', () => {",
              "  pm.expect([0, 1]).to.include(body.data.shift.is_null_shift);",
              "});",
              "",
              "// ── data.ot_reasons ──────────────────────────────────────────────────────────",
              "pm.test('data.ot_reasons is an array', () => {",
              "  pm.expect(body.data.ot_reasons).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"start_date\": \"{{startWindowStr}}\",\n  \"end_date\":   \"{{endWindowStr}}\",\n  \"user_id\":    \"{{targetEmployeeId}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/attendance/attendanceAPI/GetAttendanceDetails",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "attendance", "attendanceAPI", "GetAttendanceDetails"]
        },
        "description": "Context-bootstrap endpoint.  Returns the active shift card, static DataTable column definitions, and the org's OT reason catalogue."
      },
      "response": []
    },

    {
      "name": "02 · GetAttendancePoliciesDetails (Geofence & OT Rules)",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "test-get-attendance-policies",
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('Envelope: status === 1', () => {",
              "  pm.expect(body.status).to.eql(1);",
              "});",
              "",
              "// ── Top-level data keys ───────────────────────────────────────────────────────",
              "pm.test('data carries all five policy sections', () => {",
              "  pm.expect(body.data).to.include.all.keys([",
              "    'geo_fencing',",
              "    'attendance_policy',",
              "    'overtime_policy',",
              "    'tenant_shift',",
              "    'pay_group'",
              "  ]);",
              "});",
              "",
              "// ── geo_fencing ───────────────────────────────────────────────────────────────",
              "pm.test('data.geo_fencing is a record object (keyed by 14-char hex)', () => {",
              "  pm.expect(body.data.geo_fencing).to.be.an('object');",
              "  const entries = Object.entries(body.data.geo_fencing);",
              "  entries.forEach(([key, val]) => {",
              "    pm.expect(key).to.match(/^[0-9a-f]{14}$/i, `geo_fencing key '${key}' must be 14-char hex`);",
              "    pm.expect(val).to.include.all.keys(['label', 'long', 'latt', 'distance']);",
              "  });",
              "});",
              "",
              "// ── attendance_policy ─────────────────────────────────────────────────────────",
              "pm.test('data.attendance_policy carries policy_data and table_body', () => {",
              "  const ap = body.data.attendance_policy;",
              "  pm.expect(ap).to.include.all.keys(['policy_data', 'table_headers', 'table_body']);",
              "  pm.expect(ap.table_body).to.be.an('array');",
              "});",
              "",
              "// ── overtime_policy ───────────────────────────────────────────────────────────",
              "pm.test('data.overtime_policy.is_enabled is 0|1', () => {",
              "  pm.expect([0, 1]).to.include(body.data.overtime_policy.is_enabled);",
              "});",
              "",
              "// ── tenant_shift ──────────────────────────────────────────────────────────────",
              "pm.test('data.tenant_shift carries shift_id, shift_name, begin_time, end_time', () => {",
              "  const ts = body.data.tenant_shift;",
              "  pm.expect(ts).to.include.all.keys(['shift_id', 'shift_name', 'begin_time', 'end_time']);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"date\":    \"{{todayStr}}\",\n  \"user_id\": \"{{targetEmployeeId}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/attendance/attendanceAPI/GetAttendancePoliciesDetails",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "attendance", "attendanceAPI", "GetAttendancePoliciesDetails"]
        },
        "description": "Returns the geo-fencing pool, attendance policy rules, OT policy tiers, tenant shift card, and pay-group metadata for the resolved employee."
      },
      "response": []
    },

    {
      "name": "03 · getDayStatus (Single-Day Inspector)",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "test-get-day-status",
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "const d    = body.data;",
              "",
              "pm.test('Envelope: status === 1', () => {",
              "  pm.expect(body.status).to.eql(1);",
              "});",
              "",
              "// ── All 16 DWDayStatusData wire fields present ────────────────────────────────",
              "pm.test('data carries all 16 DWDayStatusData wire fields', () => {",
              "  pm.expect(d).to.include.all.keys([",
              "    'total_duration',",
              "    'shift_duration',",
              "    'day',",
              "    'action_label',",
              "    'clockin_time',",
              "    'clockout_time',",
              "    'clockinout_label',",
              "    'user_id',",
              "    'tenant_id',",
              "    'shift_date',",
              "    'log_id',",
              "    'clockin_time_string',",
              "    'clockout_time_string',",
              "    'enable_break',",
              "    'show_break',",
              "    'break_label'",
              "  ]);",
              "});",
              "",
              "// ── shift_duration: 'H:mm:ss' — no leading zero on hours ─────────────────────",
              "pm.test('shift_duration matches H:mm:ss pattern (no leading zero)', () => {",
              "  pm.expect(d.shift_duration).to.match(",
              "    /^\\d+:\\d{2}:\\d{2}$/,",
              "    `shift_duration '${d.shift_duration}' must be H:mm:ss format`",
              "  );",
              "});",
              "",
              "// ── day and shift_date are ISO date strings ───────────────────────────────────",
              "pm.test('day is a YYYY-MM-DD string', () => {",
              "  pm.expect(d.day).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
              "});",
              "",
              "pm.test('shift_date mirrors day', () => {",
              "  pm.expect(d.shift_date).to.eql(d.day);",
              "});",
              "",
              "// ── Permanently-null / sentinel fields ────────────────────────────────────────",
              "pm.test('enable_break is null (break management disabled)', () => {",
              "  pm.expect(d.enable_break).to.be.null;",
              "});",
              "",
              "pm.test('show_break is null (break UI suppressed)', () => {",
              "  pm.expect(d.show_break).to.be.null;",
              "});",
              "",
              "pm.test('break_label is an empty string sentinel', () => {",
              "  pm.expect(d.break_label).to.eql('');",
              "});",
              "",
              "// ── log_id: 14-char hex or empty string ───────────────────────────────────────",
              "pm.test('log_id is a 14-char hex string or empty (no daily row)', () => {",
              "  if (d.log_id !== '') {",
              "    pm.expect(d.log_id).to.match(/^[0-9a-f]{14}$/i);",
              "  }",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"date\":    \"{{todayStr}}\",\n  \"user_id\": \"{{targetEmployeeId}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/attendance/attendanceAPI/getDayStatus",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "attendance", "attendanceAPI", "getDayStatus"]
        },
        "description": "Single-date punch inspector.  Returns 16-field DWDayStatusData including shift_duration in 'H:mm:ss' (no leading zero) and all permanently-null break fields."
      },
      "response": []
    },

    {
      "name": "04 · GetLeaveCommonDetails (Leave Balance Card)",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "test-get-leave-common-details",
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('Envelope: status === 1', () => {",
              "  pm.expect(body.status).to.eql(1);",
              "});",
              "",
