    {
      "name": "07 · GetAttendanceLog (Comprehensive Monthly Ledger)",
      "event": [
        {
          "listen": "test",
          "script": {
            "id": "test-get-attendance-log",
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('Envelope: status === 1', () => {",
