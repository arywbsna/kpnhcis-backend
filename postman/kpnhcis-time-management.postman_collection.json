              "      'color_code',",
              "      'currently_available'",
              "    ]);",
              "  });",
              "});",
              "",
              "pm.test('currently_available accepts string|number union (Darwinbox legacy)', () => {",
              "  Object.values(body.data.leaves_taken).forEach(card => {",
              "    const t = typeof card.currently_available;",
              "    pm.expect(['string', 'number']).to.include(t,",
