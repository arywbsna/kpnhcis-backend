          "raw": "{\n  \"user_id\": \"{{targetEmployeeId}}\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/leaves/leavesApi/GetLeaveCommonDetails",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "leaves", "leavesApi", "GetLeaveCommonDetails"]
        },
        "description": "Leave application dashboard hydration.  Returns per-type leave cards with live balance, restriction messages, approval chain recipients, and a flat label dictionary."
      },
      "response": []
