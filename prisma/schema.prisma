// =============================================================================
// Prisma Schema — KPNHCIS Backend
// Engine  : PostgreSQL (required for JSONB + GIN index support)
// Patterns: RBAC, Adjacency List (Units), Hybrid JSONB payload columns
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, pgcrypto]
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LeaveRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED_BY_SUPERVISOR
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  SPECIAL
  UNPAID
}

// =============================================================================
// UNIT — Adjacency List (self-referencing) for Org Structure
// A unit's full path is resolved recursively via CTEs in raw queries.
// =============================================================================

model Unit {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  code        String   @unique
  description String?

  // Adjacency List: nullable parent_id for root nodes
  parentId    String?  @map("parent_id") @db.Uuid
  parent      Unit?    @relation("UnitHierarchy", fields: [parentId], references: [id])
  children    Unit[]   @relation("UnitHierarchy")

  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]

  @@index([parentId])
  @@map("units")
}

// =============================================================================
// RBAC — Roles and Permissions
// Uses a granular permission system compatible with CASL.
// Each Permission row represents: action + subject (+ optional conditions JSON).
// =============================================================================

model Permission {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action     String   // e.g. "create", "read", "update", "delete", "manage"
  subject    String   // e.g. "LeaveRequest", "Payroll", "User", "all"
  conditions Json?    // CASL conditional rule (e.g. {"unitId": "${user.unitId}"})
  description String?

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  roles      RolePermission[]

  @@unique([action, subject])
  @@index([subject])
  @@map("permissions")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system") // system roles cannot be deleted

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

// Explicit join table — allows adding metadata to the role↔permission link
model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// =============================================================================
// USER
// =============================================================================

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId    String     @unique @map("employee_id")
  email         String     @unique
  passwordHash  String     @map("password_hash")
  fullName      String     @map("full_name")
  status        UserStatus @default(ACTIVE)

  unitId        String?    @map("unit_id") @db.Uuid
  unit          Unit?      @relation(fields: [unitId], references: [id])

  // Refresh token stored hashed; null when logged out
  refreshTokenHash String? @map("refresh_token_hash")

  // Hybrid JSONB: arbitrary profile metadata (photo URL, bio, custom fields, etc.)
  // Indexed with GIN so individual keys can be queried efficiently.
  payload       Json?      @db.JsonB

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at") // soft delete

  roles         UserRole[]
  leaveRequests LeaveRequest[]
  leaveApprovals LeaveApproval[]

  @@index([unitId])
  @@index([status])
  // Raw SQL GIN index on payload is defined in a migration — see note below.
  // Prisma does not natively emit GIN index syntax; use prisma/migrations for it.
  @@map("users")
}

model UserRole {
  userId    String @map("user_id") @db.Uuid
  roleId    String @map("role_id") @db.Uuid

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// =============================================================================
// LEAVE REQUEST — State managed by XState in the application layer.
// The `status` column is the persisted state node name.
// The `payload` JSONB column stores the XState context snapshot.
// =============================================================================

model LeaveRequest {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  user        User               @relation(fields: [userId], references: [id])

  leaveType   LeaveType          @map("leave_type")
  startDate   DateTime           @map("start_date") @db.Date
  endDate     DateTime           @map("end_date") @db.Date
  totalDays   Decimal            @map("total_days") @db.Decimal(5, 1)
  reason      String
  status      LeaveRequestStatus @default(DRAFT)

  // XState context snapshot + any dynamic form fields (e.g. doctor cert URL)
  payload     Json?              @db.JsonB

  submittedAt DateTime?          @map("submitted_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  approvals   LeaveApproval[]

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

// Approval audit trail — one row per approval step
model LeaveApproval {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leaveRequestId String   @map("leave_request_id") @db.Uuid
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  approverId     String   @map("approver_id") @db.Uuid
  approver       User     @relation(fields: [approverId], references: [id])

  action         String   // "approve" | "reject" | "cancel"
  remarks        String?
  decidedAt      DateTime @default(now()) @map("decided_at")

  // Snapshot of XState event that triggered this step
  eventSnapshot  Json?    @map("event_snapshot") @db.JsonB

  @@index([leaveRequestId])
  @@map("leave_approvals")
}
