// =============================================================================
// Prisma Schema — KPNHCIS Backend
// Engine  : PostgreSQL (required for JSONB + GIN index support)
// Patterns: RBAC, Adjacency List (Units), Hybrid JSONB payload columns
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, pgcrypto]
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LeaveRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED_BY_SUPERVISOR
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  SPECIAL
  UNPAID
}

// =============================================================================
// UNIT — Adjacency List (self-referencing) for Org Structure
// A unit's full path is resolved recursively via CTEs in raw queries.
// =============================================================================

model Unit {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  code        String   @unique
  description String?

  // Adjacency List: nullable parent_id for root nodes
  parentId    String?  @map("parent_id") @db.Uuid
  parent      Unit?    @relation("UnitHierarchy", fields: [parentId], references: [id])
  children    Unit[]   @relation("UnitHierarchy")

  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]

  @@index([parentId])
  @@map("units")
}

// =============================================================================
// RBAC — Roles and Permissions
// Uses a granular permission system compatible with CASL.
// Each Permission row represents: action + subject (+ optional conditions JSON).
// =============================================================================

model Permission {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action     String   // e.g. "create", "read", "update", "delete", "manage"
  subject    String   // e.g. "LeaveRequest", "Payroll", "User", "all"
  conditions Json?    // CASL conditional rule (e.g. {"unitId": "${user.unitId}"})
  description String?

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  roles      RolePermission[]

  @@unique([action, subject])
  @@index([subject])
  @@map("permissions")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system") // system roles cannot be deleted

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

// Explicit join table — allows adding metadata to the role↔permission link
model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// =============================================================================
// USER
// =============================================================================

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  employeeId    String     @unique @map("employee_id")
  email         String     @unique
  passwordHash  String     @map("password_hash")
  fullName      String     @map("full_name")
  status        UserStatus @default(ACTIVE)

  unitId        String?    @map("unit_id") @db.Uuid
  unit          Unit?      @relation(fields: [unitId], references: [id])

  // Self-referencing manager hierarchy — populated by Darwinbox profile sync.
  // managerId stores the UUID of this user's direct line manager.
  // Resoled at sync time by looking up the manager's employeeId (Darwinbox
  // `reporting_manager_employee_id`) in the users table.
  managerId     String?    @map("manager_id") @db.Uuid
  manager       User?      @relation("DirectReports", fields: [managerId], references: [id])
  subordinates  User[]     @relation("DirectReports")

  // Refresh token stored hashed; null when logged out
  refreshTokenHash String? @map("refresh_token_hash")

  // Hybrid JSONB: arbitrary profile metadata (photo URL, bio, custom fields, etc.)
  // Indexed with GIN so individual keys can be queried efficiently.
  payload       Json?      @db.JsonB

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at") // soft delete

  roles            UserRole[]
  leaveRequests    LeaveRequest[]
  leaveApprovals   LeaveApproval[]
  shiftAssignments ShiftAssignment[]
  attendanceDaily  AttendanceDaily[]
  attendanceLogs   AttendanceLog[]
  leaveBalances    LeaveBalance[]

  @@index([unitId])
  @@index([managerId])
  @@index([status])
  // Raw SQL GIN index on payload is defined in a migration — see note below.
  // Prisma does not natively emit GIN index syntax; use prisma/migrations for it.
  @@map("users")
}

model UserRole {
  userId    String @map("user_id") @db.Uuid
  roleId    String @map("role_id") @db.Uuid

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// =============================================================================
// TIME MANAGEMENT — Attendance & Leave Balance
// =============================================================================

enum DayType {
  WORKING_DAY
  WEEKOFF
  PUBLIC_HOLIDAY
  REST_DAY
}

enum AttendanceSource {
  BIOMETRIC
  MOBILE_GPS
  WEB
}

// Canonical shift definition.  Policy rules (grace thresholds, overtime caps,
// absent-cutoff minutes, weekend day mask) live in the `payload` JSONB column
// so they can evolve without schema migrations.
model ShiftDefinition {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String   @unique
  code             String   @unique
  startTime        String   @map("start_time")          // "HH:MM" 24h
  endTime          String   @map("end_time")            // "HH:MM" 24h
  isOvernight      Boolean  @default(false) @map("is_overnight")
  gracePeriodMins  Int      @default(0)  @map("grace_period_mins")
  overtimeEligible Boolean  @default(true) @map("overtime_eligible")
  weekendDays      Int[]    @map("weekend_days")        // 0=Sun … 6=Sat

  // JSONB: { rules: ShiftPolicyRule[], overtimeCapMins, absentCutoffMins }
  payload          Json?    @db.JsonB

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt     @map("updated_at")

  assignments      ShiftAssignment[]
  attendanceDaily  AttendanceDaily[]

  @@map("shift_definitions")
}

// Per-employee effective shift window.  An employee can have overlapping
// assignments (e.g. permanent + project-based override); the service picks the
// latest effective record that has not yet expired.
model ShiftAssignment {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String          @map("user_id")   @db.Uuid
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftId       String          @map("shift_id")  @db.Uuid
  shift         ShiftDefinition @relation(fields: [shiftId], references: [id])
  effectiveDate DateTime        @map("effective_date") @db.Date
  expiryDate    DateTime?       @map("expiry_date")    @db.Date

  // JSONB: branch overrides, dinas-luar location pool extensions
  payload       Json?           @db.JsonB

  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt     @map("updated_at")

  @@index([userId, effectiveDate])
  @@map("shift_assignments")
}

// One row per employee per calendar day.  Updated in-place by the clock-event
// pipeline as events arrive throughout the day.
//
// JSONB payload stores:
//   currentLocationContext  — last-accepted geofence location snapshot
//   allowedLocationsPool    — pool snapshot at the time of the last event
//   dailySummaryJobId       — BullMQ job ID for the end-of-day aggregation
model AttendanceDaily {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String          @map("user_id")       @db.Uuid
  user           User            @relation(fields: [userId], references: [id])
  attendanceDate DateTime        @map("attendance_date") @db.Date
  shiftId        String?         @map("shift_id")      @db.Uuid
  shift          ShiftDefinition? @relation(fields: [shiftId], references: [id])
  firstClockIn   DateTime?       @map("first_clock_in")
  lastClockOut   DateTime?       @map("last_clock_out")
  totalWorkMins  Int?            @map("total_work_mins")
  isLate         Boolean         @default(false) @map("is_late")
  lateByMins     Int?            @map("late_by_mins")
  overtimeMins   Int?            @map("overtime_mins")
  dayType        DayType         @default(WORKING_DAY) @map("day_type")

  payload        Json?           @db.JsonB

  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt     @map("updated_at")

  logs           AttendanceLog[]

  @@unique([userId, attendanceDate])
  @@index([userId])
  @@index([attendanceDate])
  @@map("attendance_daily")
}

// Immutable raw event stream.  One row per clock-in or clock-out tap.
// Bulk-read by GetAttendanceLog; written by the clock-event pipeline.
model AttendanceLog {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyId          String          @map("daily_id") @db.Uuid
  daily            AttendanceDaily @relation(fields: [dailyId], references: [id], onDelete: Cascade)
  userId           String          @map("user_id")  @db.Uuid
  user             User            @relation(fields: [userId], references: [id])
  eventType        String          @map("event_type")   // "clock_in" | "clock_out"
  source           AttendanceSource
  loggedAt         DateTime        @map("logged_at")
  latitude         Decimal?        @db.Decimal(10, 8)
  longitude        Decimal?        @db.Decimal(11, 8)
  resolvedLocation String?         @map("resolved_location")
  geofenceMatched  Boolean?        @map("geofence_matched")

  // JSONB: { deviceInfo: {deviceId, deviceType, osVersion, appVersion}, ipAddress, antiFraudFlags }
  payload          Json?           @db.JsonB

  createdAt        DateTime        @default(now()) @map("created_at")

  @@index([dailyId])
  @@index([userId, loggedAt])
  @@map("attendance_logs")
}

// Per-employee per-year leave balance per category.
// entitled + carried - used - pending = remaining (computed in the service layer).
// Policy config (gender constraints, document requirements, half-day rules) lives
// in the `payload` JSONB to avoid adding a column per policy knob.
model LeaveBalance {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  year      Int
  leaveType LeaveType @map("leave_type")
  entitled  Decimal   @db.Decimal(5, 1)
  used      Decimal   @db.Decimal(5, 1)
  pending   Decimal   @db.Decimal(5, 1)
  carried   Decimal   @db.Decimal(5, 1)

  // JSONB: { expiryDate, color, allowHalfDay, requiresDocument, documentTypes,
  //          genderConstraint, maxConsecutiveDays, minAdvanceDays }
  payload   Json?     @db.JsonB

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt     @map("updated_at")

  @@unique([userId, year, leaveType])
  @@index([userId, year])
  @@map("leave_balances")
}

// Countrywide and regional public holidays.  Used by getDayStatus and
// GetDataForLeavePattern to populate blackout date arrays.
model PublicHoliday {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date        DateTime @db.Date
  name        String
  countryCode String   @map("country_code")
  regionCode  String?  @map("region_code")
  isOptional  Boolean  @default(false) @map("is_optional")

  payload     Json?    @db.JsonB

  @@unique([date, countryCode])
  @@index([date])
  @@map("public_holidays")
}

// =============================================================================
// LEAVE REQUEST — State managed by XState in the application layer.
// The `status` column is the persisted state node name.
// The `payload` JSONB column stores the XState context snapshot.
// =============================================================================

model LeaveRequest {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  user        User               @relation(fields: [userId], references: [id])

  leaveType   LeaveType          @map("leave_type")
  startDate   DateTime           @map("start_date") @db.Date
  endDate     DateTime           @map("end_date") @db.Date
  totalDays   Decimal            @map("total_days") @db.Decimal(5, 1)
  reason      String
  status      LeaveRequestStatus @default(DRAFT)

  // XState context snapshot + any dynamic form fields (e.g. doctor cert URL)
  payload     Json?              @db.JsonB

  submittedAt DateTime?          @map("submitted_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  approvals   LeaveApproval[]

  @@index([userId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

// Approval audit trail — one row per approval step
model LeaveApproval {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leaveRequestId String   @map("leave_request_id") @db.Uuid
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  approverId     String   @map("approver_id") @db.Uuid
  approver       User     @relation(fields: [approverId], references: [id])

  action         String   // "approve" | "reject" | "cancel"
  remarks        String?
  decidedAt      DateTime @default(now()) @map("decided_at")

  // Snapshot of XState event that triggered this step
  eventSnapshot  Json?    @map("event_snapshot") @db.JsonB

  @@index([leaveRequestId])
  @@map("leave_approvals")
}
