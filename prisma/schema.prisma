// =============================================================================
// Prisma Schema — KPNHCIS Backend
// Engine  : PostgreSQL (required for JSONB + GIN index support)
// Patterns: RBAC, Adjacency List (Units), Hybrid JSONB payload columns,
//           Multi-Tenant (Subsidiary), XState leave workflow
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, pgcrypto]
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LeaveRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED_BY_SUPERVISOR
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  SPECIAL
  UNPAID
}

// -----------------------------------------------------------------------------
// P1 — Core HR Framework enums
// -----------------------------------------------------------------------------

/// Legal contract classification under Indonesian manpower law.
/// PKWTT = Perjanjian Kerja Waktu Tidak Tertentu (permanent/open-ended).
/// PKWT  = Perjanjian Kerja Waktu Tertentu (fixed-term, max 5 years by law).
enum ContractType {
  PKWTT    // Permanent — no end date
  PKWT     // Fixed-term — endDate is mandatory
  INTERN   // Internship / magang program
  CONTRACT // Outsourced / vendor-managed engagement
}

/// Lifecycle state of an employment contract.
/// EXPIRED   = endDate has passed without renewal.
/// TERMINATED = ended early by mutual agreement or disciplinary action.
enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

/// Career movement classification used to categorise EmployeeMutation rows.
/// TRANSFER_PT captures cross-subsidiary reassignments that involve a legal
/// entity change (e.g. KPN_HO → KPN_LOG) — these require an SK decree.
enum MutationType {
  PROMOTION    // Vertical upward movement (grade / tier increase)
  DEMOTION     // Vertical downward movement
  MUTATION     // Lateral move within the same subsidiary
  TRANSFER_PT  // Cross-subsidiary transfer; triggers a new employment contract
}

/// Approval workflow state for EmployeeMutation records.
enum MutationStatus {
  PENDING
  APPROVED
  REJECTED
}

// -----------------------------------------------------------------------------
// P2 — Payroll & Workflow Engine enums
// -----------------------------------------------------------------------------

/// Lifecycle gate for a payroll processing cycle.
/// Transitions are one-directional: OPEN → PROCESSING → CLOSED → ARCHIVED.
/// Only OPEN periods accept new or amended payslip drafts.
/// CLOSED periods trigger the payment disbursement pipeline.
enum PayrollPeriodStatus {
  OPEN        // Accepting new payslip drafts; editable
  PROCESSING  // Payroll run in progress — locked for editing; BullMQ job active
  CLOSED      // Finalised and approved — disbursement pipeline triggered
  ARCHIVED    // Historical period; read-only; retained for statutory compliance
}

/// Document-level lifecycle state of an individual employee payslip.
/// Transitions: DRAFT → APPROVED → PAID
enum PayslipStatus {
  DRAFT    // Auto-generated by the payroll engine; pending HR/finance review
  APPROVED // Verified and signed off by the authorised approver
  PAID     // Payment disbursed; bank transfer reference recorded in payload
}

/// Classification of a single payslip line item.
/// Used for component-level grouping on the payslip UI and for statutory
/// reporting (e.g. total EARNING for BPJS TK base, total DEDUCTION for PPh21).
enum PayslipLineType {
  EARNING    // Income component: gaji pokok, tunjangan tetap, lembur, bonus
  DEDUCTION  // Reduction component: absensi, cicilan, BPJS, PPh21
}

/// Domain module to which a WorkflowDefinition belongs.
/// Used to namespace generic approval blueprints and route Task Box items
/// to the correct service handler and XState machine factory.
enum WorkflowModule {
  LEAVE       // Izin & cuti (leave_requests)
  ATTENDANCE  // Koreksi absensi (attendance_daily)
  MUTATION    // Mutasi / promosi (employee_mutations)
  PAYROLL     // Persetujuan payslip (payslips)
}

/// Runtime lifecycle state of a WorkflowInstance ticket in the Task Box.
/// RUNNING      — at least one approval step is pending action.
/// COMPLETED    — all steps approved; the entity status has been finalized.
/// REJECTED     — one step issued REJECT; chain terminated.
/// TERMINATED   — cancelled by HR admin outside the normal approval chain.
enum WorkflowInstanceStatus {
  RUNNING
  COMPLETED
  REJECTED
  TERMINATED
}

// =============================================================================
// SUBSIDIARY — Corporate Legal Entity / Multi-Tenant Boundary Root
//
// Design contract:
//   • One Subsidiary = one legal entity (PT), one payroll cycle, one CASL
//     permission namespace, one Redis/BullMQ queue namespace.
//   • All Units and Users must declare their Subsidiary owner.
//   • Subsidiary deletion is blocked by Restrict constraints on Unit and User.
//     Decommission sequence: deactivate Users → archive Units → then remove.
// =============================================================================

model Subsidiary {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  /// Immutable short business code. Used as the namespace key in Redis cache
  /// entries, BullMQ queue name prefixes, and CASL condition scoping at runtime.
  /// Examples: "KPN_HO", "KPN_LOGISTIK", "KPN_ENERGI", "KPN_PROPERTI"
  /// Set once at creation — never mutate; references in payload JSONB break.
  code        String   @unique

  /// Official legal entity name as registered with the government (Kemenkumham).
  /// Printed on payslips, contracts, and compliance reports verbatim.
  name        String

  /// External company identifier sourced from the legacy HRIS / Darwinbox sync.
  /// Acts as a fallback lookup key when hydrating records whose payload JSONB
  /// stores a legacy `companyId` field rather than our internal subsidiary UUID.
  /// Unique constraint enforces 1-to-1 parity with the upstream system record.
  companyId   String   @unique @map("company_id")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  /// All organisational units (Divisi, Departemen, Cabang) under this entity.
  /// Back-reference for Unit.subsidiary — onDelete: Restrict declared on Unit side.
  units       Unit[]

  /// All employees directly bound to this subsidiary.
  /// Denormalised tenant anchor — stays in sync with unit.subsidiaryId via the
  /// profile-sync service. Enables O(1) tenant-scoped queries without a JOIN
  /// through the units table.
  /// Back-reference for User.subsidiary — onDelete: Restrict declared on User side.
  users       User[]

  // ---------------------------------------------------------------------------
  // P1 — Core HR Framework back-references
  // ---------------------------------------------------------------------------

  /// All job positions defined for this legal entity.
  jobPositions     JobPosition[]

  /// All compensation tiers / grade bands for this legal entity.
  gradeLevels      GradeLevel[]

  /// All employment contracts issued under this legal entity.
  contracts        EmploymentContract[]

  /// Mutation records where this subsidiary was the employee's prior entity.
  /// Named relation required — EmployeeMutation has two FKs to Subsidiary.
  mutationsAsOldSubsidiary EmployeeMutation[] @relation("MutationOldSubsidiary")

  /// Mutation records where this subsidiary is the employee's destination entity.
  mutationsAsNewSubsidiary EmployeeMutation[] @relation("MutationNewSubsidiary")

  // ---------------------------------------------------------------------------
  // P2 — Payroll & Workflow Engine back-references
  // ---------------------------------------------------------------------------

  /// All payroll processing cycles owned by this legal entity.
  /// Back-reference for PayrollPeriod.subsidiary — onDelete: Restrict on child.
  payrollPeriods      PayrollPeriod[]

  /// All payslip records issued under this legal entity.
  /// Denormalised subsidiary anchor for fast tenant-scoped payroll queries.
  payslips            Payslip[]

  /// All workflow approval blueprints configured for this legal entity.
  workflowDefinitions WorkflowDefinition[]

  /// All live workflow approval tickets running under this legal entity.
  workflowInstances   WorkflowInstance[]

  @@map("subsidiaries")
}

// =============================================================================
// UNIT — Adjacency List Org Structure with Mandatory Subsidiary Anchor
//
// Design contract:
//   • Uses self-referencing parent_id (Adjacency List) for the org tree.
//     Full ancestor paths are resolved via WITH RECURSIVE CTEs in raw SQL.
//   • subsidiaryId is mandatory — no Unit may exist without a declared legal
//     entity owner. PostgreSQL FK enforces this at the database level.
//   • Deletion behaviour:
//       Unit.parent      → Restrict (implicit) — cannot delete a parent unit
//                          while child units still reference it.
//       Unit.subsidiary  → onDelete: Restrict — cannot delete a Subsidiary while
//                          it owns active Units; deactivate or reassign first.
//
// ⚠ Migration note for subsidiaryId NOT NULL:
//   Before applying this migration, backfill all existing rows:
//     UPDATE units
//       SET subsidiary_id = '<your-anchor-subsidiary-uuid>'
//     WHERE subsidiary_id IS NULL;
//   Then run `prisma migrate dev` to apply the NOT NULL constraint.
// =============================================================================

model Unit {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  /// Human-readable display name. Mutable — shown in org charts and reports.
  name        String

  /// Immutable short code for the unit. Used in API filters and report exports.
  /// Examples: "DIV_HC", "DEPT_IT_INFRA", "CAB_SBY_01"
  code        String   @unique

  /// Optional long-form description of the unit's responsibilities.
  description String?

  // ---------------------------------------------------------------------------
  // ADJACENCY LIST — Org Hierarchy
  // ---------------------------------------------------------------------------

  /// Null only for root nodes (e.g., top-level Direktorat).
  /// Deep-path traversal uses a recursive CTE:
  ///   WITH RECURSIVE unit_tree AS (
  ///     SELECT id, parent_id FROM units WHERE id = $1
  ///     UNION ALL
  ///     SELECT u.id, u.parent_id FROM units u JOIN unit_tree t ON u.id = t.parent_id
  ///   ) SELECT * FROM unit_tree;
  parentId    String?    @map("parent_id") @db.Uuid
  parent      Unit?      @relation("UnitHierarchy", fields: [parentId], references: [id])
  children    Unit[]     @relation("UnitHierarchy")

  // ---------------------------------------------------------------------------
  // TENANT ANCHOR — Subsidiary Binding (MANDATORY)
  // ---------------------------------------------------------------------------

  /// Every Unit must declare its Subsidiary (legal entity) owner.
  /// This is the primary cross-subsidiary isolation boundary at the DB level.
  subsidiaryId String     @map("subsidiary_id") @db.Uuid

  /// onDelete: Restrict — a Subsidiary cannot be hard-deleted while it owns
  /// active Units. Decommission sequence: reassign/archive Units first.
  subsidiary   Subsidiary @relation(fields: [subsidiaryId], references: [id], onDelete: Restrict)

  /// Soft-delete flag. Use isActive = false to decommission units rather than
  /// hard DELETE — preserves referential integrity for historical User records.
  isActive    Boolean  @default(true)  @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  /// Employees currently assigned to this unit.
  /// Back-reference for User.unit — onDelete: Restrict declared on User side.
  users       User[]

  // ---------------------------------------------------------------------------
  // P1 — Core HR Framework back-references
  // ---------------------------------------------------------------------------

  /// Job positions whose reporting home is this unit.
  jobPositions         JobPosition[]

  /// Mutation records where this unit was the employee's prior assignment.
  mutationsAsOldUnit   EmployeeMutation[] @relation("MutationOldUnit")

  /// Mutation records where this unit is the employee's destination assignment.
  mutationsAsNewUnit   EmployeeMutation[] @relation("MutationNewUnit")

  // ---------------------------------------------------------------------------
  // INDEXES
  // ---------------------------------------------------------------------------

  /// B-Tree on parent_id — accelerates immediate-children lookups and
  /// recursive CTE scans that traverse the adjacency list level by level.
  @@index([parentId])

  /// Composite B-Tree on (subsidiary_id, id).
  /// The subsidiaryId prefix makes this the query planner's first choice for
  /// any tenant-scoped org-chart query: "SELECT * FROM units WHERE subsidiary_id = $1".
  /// Including id makes the index covering for PK lookups within a subsidiary
  /// context — avoids a heap fetch on the most common cross-tenant pattern.
  @@index([subsidiaryId, id])

  @@map("units")
}

// =============================================================================
// RBAC — Roles and Permissions
// Uses a granular permission system compatible with CASL.
// Each Permission row represents: action + subject (+ optional conditions JSON).
// =============================================================================

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  action      String   // e.g. "create", "read", "update", "delete", "manage"
  subject     String   // e.g. "LeaveRequest", "Payroll", "User", "all"
  conditions  Json?    // CASL conditional rule (e.g. {"unitId": "${user.unitId}"})
  description String?

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  roles       RolePermission[]

  @@unique([action, subject])
  @@index([subject])
  @@map("permissions")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system") // system roles cannot be deleted

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt      @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

// Explicit join table — allows adding metadata to the role↔permission link
model RolePermission {
  roleId       String @map("role_id")       @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role         Role       @relation(fields: [roleId],       references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// =============================================================================
// USER — Core Employee Record
//
// Deletion strategy — two tiers:
//
//   SOFT DELETE (normal deactivation):
//     Set deletedAt timestamp + status = INACTIVE. All relations intact.
//     Used for: resignation, termination, contract expiry, suspension.
//
//   HARD DELETE (GDPR erasure request only):
//     Issues a physical DELETE on the users row. Triggers a controlled
//     cascade chain that purges all owned ledger data with zero orphans:
//       User → LeaveRequest   (Cascade) → LeaveApproval   (Cascade)
//       User → AttendanceDaily (Cascade) → AttendanceLog  (Cascade)
//       User → LeaveBalance   (Cascade)
//       User → ShiftAssignment (Cascade)
//       User → UserRole        (Cascade)
//
//     Hard delete is BLOCKED if:
//       • The user is assigned to an active Unit        (unit.onDelete: Restrict)
//       • The user is assigned to a Subsidiary          (subsidiary.onDelete: Restrict)
//       • The user has issued formal leave approvals    (LeaveApproval.approver Restrict)
//     Resolution: soft-delete first, then resolve Restrict references before hard-delete.
// =============================================================================

model User {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  /// Immutable HR employee number (e.g. "EMP-2024-00123"). Sourced from the
  /// legacy HRIS / Darwinbox. Used as the external identity key for sync ops.
  employeeId    String     @unique @map("employee_id")

  email         String     @unique
  passwordHash  String     @map("password_hash")
  fullName      String     @map("full_name")
  status        UserStatus @default(ACTIVE)

  // ---------------------------------------------------------------------------
  // STRUCTURAL RELATIONS — onDelete: Restrict
  // Unit and Subsidiary are master data structures that define the org chart
  // and CASL permission namespace. Deleting them while employees are assigned
  // would corrupt tenant isolation and break org-chart queries.
  // Correct decommission path: set isActive = false on the Unit/Subsidiary first.
  // ---------------------------------------------------------------------------

  /// The organisational unit (Departemen / Divisi / Cabang) this employee
  /// belongs to. Nullable to support system accounts and root-level executives
  /// not assigned to a specific org node.
  unitId        String?    @map("unit_id") @db.Uuid

  /// onDelete: Restrict — blocks deletion of a Unit that still has assigned
  /// employees. Reassign or soft-delete employees before removing the Unit.
  unit          Unit?      @relation(fields: [unitId], references: [id], onDelete: Restrict)

  /// Denormalised subsidiary anchor. Must always equal unit.subsidiaryId when
  /// unitId is set — the profile-sync service enforces this invariant.
  /// Nullable to support system accounts with no unit assignment.
  subsidiaryId  String?    @map("subsidiary_id") @db.Uuid

  /// onDelete: Restrict — blocks deletion of a Subsidiary while employees are
  /// registered under it. Full decommission requires soft-deleting users first.
  subsidiary    Subsidiary? @relation(fields: [subsidiaryId], references: [id], onDelete: Restrict)

  // ---------------------------------------------------------------------------
  // P1 — Core HR Position & Grade Binding
  // Both nullable — system accounts and provisioned users may not yet have an
  // assigned position or grade. SetNull on delete so restructuring master data
  // (position or grade removal) does not block or corrupt employee records.
  // ---------------------------------------------------------------------------

  jobPositionId String?      @map("job_position_id") @db.Uuid
  jobPosition   JobPosition? @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)

  gradeLevelId  String?      @map("grade_level_id") @db.Uuid
  gradeLevel    GradeLevel?  @relation(fields: [gradeLevelId], references: [id], onDelete: SetNull)

  // ---------------------------------------------------------------------------
  // SELF-REFERENCING MANAGER HIERARCHY — onDelete: SetNull
  // Populated during Darwinbox profile sync via reporting_manager_employee_id.
  // onDelete: SetNull — if a manager is hard-deleted, their subordinates' records
  // are preserved but managerId is set to NULL. Prevents Restrict from blocking
  // deletion of managers who have direct reports.
  // ---------------------------------------------------------------------------

  managerId     String?    @map("manager_id") @db.Uuid

  /// onDelete: SetNull — subordinates lose their manager reference on hard-delete
  /// of the manager user; their own User records remain fully intact.
  manager       User?      @relation("DirectReports", fields: [managerId], references: [id], onDelete: SetNull)
  subordinates  User[]     @relation("DirectReports")

  // ---------------------------------------------------------------------------
  // AUTH
  // ---------------------------------------------------------------------------

  /// Hashed refresh token (bcrypt). Set to null on logout or token rotation.
  refreshTokenHash String? @map("refresh_token_hash")

  // ---------------------------------------------------------------------------
  // HYBRID JSONB PAYLOAD
  // ---------------------------------------------------------------------------

  /// Arbitrary profile metadata: photo URL, national ID, bank account, bio,
  /// positionIds[] for PLT / dual-position XState guards, Darwinbox sync fields.
  /// ⚠ GIN index on this column is hand-authored in:
  ///     prisma/migrations/20260522235959_gin_indexes/migration.sql
  ///   DO NOT allow Prisma to auto-generate DROP INDEX for this field.
  payload       Json?      @db.JsonB

  // ---------------------------------------------------------------------------
  // TIMESTAMPS
  // ---------------------------------------------------------------------------

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt      @map("updated_at")

  /// Soft-delete sentinel. Set this instead of issuing a hard DELETE for all
  /// normal deactivation flows (resignation, termination, contract end).
  /// Hard DELETE is reserved for GDPR erasure requests only.
  deletedAt     DateTime?  @map("deleted_at")

  // ---------------------------------------------------------------------------
  // BACK-REFERENCES — LEDGER / TIMELINE (onDelete: Cascade declared on child)
  // Owned records tied to this user's identity. Purged atomically via the
  // cascade chain when a hard DELETE is issued on the User row.
  // ---------------------------------------------------------------------------

  /// The user's own leave submissions. Cascade-deleted with the user.
  /// LeaveApproval rows swept via LeaveRequest's own Cascade.
  leaveRequests    LeaveRequest[]

  /// Daily attendance aggregate rows. Cascade-deleted with the user.
  /// AttendanceLog rows swept via AttendanceDaily's own Cascade.
  attendanceDaily  AttendanceDaily[]

  /// Raw clock-event stream. Cascade-deleted via the direct userId FK AND
  /// via AttendanceDaily's cascade (indirect path). Both paths are Cascade
  /// to avoid FK Restrict blocking the cascade chain on User deletion.
  attendanceLogs   AttendanceLog[]

  /// Annual leave balance ledger. Cascade-deleted with the user.
  leaveBalances    LeaveBalance[]

  /// Shift schedule assignments. Cascade-deleted with the user.
  shiftAssignments ShiftAssignment[]

  // ---------------------------------------------------------------------------
  // BACK-REFERENCES — AUDIT / APPROVAL (onDelete: Restrict declared on child)
  // A user who has issued formal approval decisions is part of an immutable
  // audit trail. Their User record cannot be hard-deleted while these exist.
  // Use soft-delete (deletedAt) for departing approvers.
  // ---------------------------------------------------------------------------

  /// Approval decisions this user has issued as an approver.
  /// onDelete: Restrict is declared on LeaveApproval.approver.
  leaveApprovals   LeaveApproval[]

  // ---------------------------------------------------------------------------
  // BACK-REFERENCES — P1 Core HR
  // ---------------------------------------------------------------------------

  /// All employment contracts (PKWTT, PKWT, etc.) for this employee.
  /// Cascade-deleted with the user on GDPR hard-delete.
  contracts          EmploymentContract[]

  // ---------------------------------------------------------------------------
  // BACK-REFERENCES — P2 Payroll
  // onDelete: Restrict declared on Payslip.user — a User record cannot be
  // hard-deleted while historical payslips exist. Use soft-delete (deletedAt)
  // for departed employees; payslips must be retained for statutory audits.
  // ---------------------------------------------------------------------------

  /// All payslips issued to this employee across all payroll periods.
  payslips           Payslip[]

  /// Career movement history (promotion, mutation, transfer, demotion).
  /// Named relation — EmployeeMutation also has an approvedById FK to User.
  /// Cascade-deleted with the user on GDPR hard-delete.
  mutations          EmployeeMutation[]   @relation("MutationEmployee")

  /// Mutation requests this user approved in their capacity as HR officer / manager.
  /// onDelete: SetNull declared on EmployeeMutation.approvedBy — hard-deleting
  /// an approver clears the reference but preserves the mutation record.
  mutationsApproved  EmployeeMutation[]   @relation("MutationApprover")

  // ---------------------------------------------------------------------------
  // BACK-REFERENCES — RBAC
  // ---------------------------------------------------------------------------

  roles            UserRole[]

  // ---------------------------------------------------------------------------
  // INDEXES
  // ---------------------------------------------------------------------------

  @@index([unitId])
  @@index([managerId])
  @@index([status])
  @@index([subsidiaryId])

  /// Composite: "all ACTIVE employees in subsidiary X" — most common HR
  /// dashboard and payroll scoping query.
  @@index([subsidiaryId, status])

  /// Composite: "all ACTIVE employees in unit X" — org-chart headcount and
  /// unit-scoped CASL permission condition evaluation.
  @@index([unitId, status])

  /// P1: position-scoped headcount query — "how many employees hold position X?"
  @@index([jobPositionId])

  /// P1: grade-scoped headcount query — "how many employees are at grade G2?"
  @@index([gradeLevelId])

  @@map("users")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// =============================================================================
// TIME MANAGEMENT — Attendance & Leave Balance
// =============================================================================

enum DayType {
  WORKING_DAY
  WEEKOFF
  PUBLIC_HOLIDAY
  REST_DAY
}

enum AttendanceSource {
  BIOMETRIC
  MOBILE_GPS
  WEB
}

// Canonical shift definition. Policy rules (grace thresholds, overtime caps,
// absent-cutoff minutes, weekend day mask) live in the `payload` JSONB column
// so they can evolve without schema migrations.
model ShiftDefinition {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String   @unique
  code             String   @unique
  startTime        String   @map("start_time")         // "HH:MM" 24h
  endTime          String   @map("end_time")           // "HH:MM" 24h
  isOvernight      Boolean  @default(false) @map("is_overnight")
  gracePeriodMins  Int      @default(0)     @map("grace_period_mins")
  overtimeEligible Boolean  @default(true)  @map("overtime_eligible")
  weekendDays      Int[]    @map("weekend_days")       // 0=Sun … 6=Sat

  // JSONB: { rules: ShiftPolicyRule[], overtimeCapMins, absentCutoffMins }
  payload          Json?    @db.JsonB

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt      @map("updated_at")

  assignments      ShiftAssignment[]
  attendanceDaily  AttendanceDaily[]

  @@map("shift_definitions")
}

// Per-employee effective shift window. An employee can have overlapping
// assignments (e.g. permanent + project-based override); the service picks the
// latest effective record that has not yet expired.
model ShiftAssignment {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String          @map("user_id")  @db.Uuid
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  shiftId       String          @map("shift_id") @db.Uuid

  /// onDelete: Restrict (implicit) — a ShiftDefinition cannot be hard-deleted
  /// while active assignments reference it. Archive via isActive logic instead.
  shift         ShiftDefinition @relation(fields: [shiftId], references: [id])

  effectiveDate DateTime        @map("effective_date") @db.Date
  expiryDate    DateTime?       @map("expiry_date")    @db.Date

  // JSONB: branch overrides, dinas-luar location pool extensions
  payload       Json?           @db.JsonB

  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt      @map("updated_at")

  @@index([userId, effectiveDate])
  @@map("shift_assignments")
}

// =============================================================================
// ATTENDANCE DAILY — One Row per Employee per Calendar Day
//
// Acts as the aggregate header for all clock events within a single work day.
// Updated in-place by the clock-event pipeline as punch events arrive.
// Resolved to a final summary by the BullMQ `daily-summary-aggregate` job.
//
// Deletion contract:
//   user  → onDelete: Cascade
//     Attendance records are owned data. On GDPR hard-delete of a User, all
//     daily records are purged. This cascade propagates further to AttendanceLog
//     rows via AttendanceLog.daily (Cascade), producing a full timeline purge.
//   shift → Restrict (implicit) — ShiftDefinition cannot be hard-deleted if
//     daily records reference it. Use archiving / isActive logic instead.
// =============================================================================

model AttendanceDaily {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId         String           @map("user_id") @db.Uuid

  /// onDelete: Cascade — attendance data is owned by its employee record.
  /// GDPR hard-delete of a User purges all daily attendance rows, which
  /// further cascades to AttendanceLog via AttendanceLog.daily Cascade.
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  attendanceDate DateTime         @map("attendance_date") @db.Date
  shiftId        String?          @map("shift_id") @db.Uuid

  /// Implicit onDelete: Restrict — ShiftDefinition deletion blocked if daily
  /// records reference it. Archive or deactivate shifts; never hard-delete.
  shift          ShiftDefinition? @relation(fields: [shiftId], references: [id])

  firstClockIn   DateTime?        @map("first_clock_in")
  lastClockOut   DateTime?        @map("last_clock_out")

  /// Total accumulated work minutes. Computed by daily-summary-aggregate BullMQ job.
  totalWorkMins  Int?             @map("total_work_mins")

  isLate         Boolean          @default(false) @map("is_late")
  lateByMins     Int?             @map("late_by_mins")
  overtimeMins   Int?             @map("overtime_mins")
  dayType        DayType          @default(WORKING_DAY) @map("day_type")

  /// JSONB: currentLocationContext, allowedLocationsPool, dailySummaryJobId.
  /// Written by the clock-event pipeline; read by the daily aggregation job.
  payload        Json?            @db.JsonB

  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt      @map("updated_at")

  /// Raw clock events composing this daily record. Cascade-deleted with this row.
  logs           AttendanceLog[]

  @@unique([userId, attendanceDate])
  @@index([userId])
  @@index([attendanceDate])
  @@map("attendance_daily")
}

// =============================================================================
// ATTENDANCE LOG — Immutable Raw Clock Event Stream
//
// One row per clock-in or clock-out tap. Written once by the clock-event
// pipeline; never mutated. Bulk-read by GetAttendanceLog and anti-fraud-scan.
//
// Deletion contract — TWO cascade paths, both must be Cascade:
//
//   daily (dailyId) → onDelete: Cascade  [already set — preserved]
//     When an AttendanceDaily row is deleted, all its child log entries
//     are swept atomically.
//
//   user (userId)   → onDelete: Cascade  [NEW — critical fix]
//     AttendanceLog has a direct FK to users(id) in addition to the indirect
//     path via daily_id → attendance_daily.user_id.
//
//     ⚠ PostgreSQL FK constraint evaluation:
//       When deleting a User, PostgreSQL evaluates ALL FK constraints referencing
//       users(id) BEFORE processing any Cascade actions. If attendance_logs.user_id
//       were Restrict, it would block the User DELETE immediately — even though the
//       AttendanceDaily cascade would eventually clean up the logs via daily_id.
//       Setting this to Cascade eliminates the blocking constraint and ensures
//       the full cascade chain completes without a constraint violation error.
// =============================================================================

model AttendanceLog {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  dailyId          String           @map("daily_id") @db.Uuid

  /// onDelete: Cascade — log entries are children of the daily aggregate.
  /// Purged automatically when the parent AttendanceDaily row is deleted.
  daily            AttendanceDaily  @relation(fields: [dailyId], references: [id], onDelete: Cascade)

  userId           String           @map("user_id") @db.Uuid

  /// onDelete: Cascade — secondary cascade path required to prevent FK Restrict
  /// from blocking the User → AttendanceDaily cascade chain on User hard-delete.
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  eventType        String           @map("event_type")  // "clock_in" | "clock_out"
  source           AttendanceSource

  /// Wall-clock timestamp of the raw event as received from device or gate. UTC.
  loggedAt         DateTime         @map("logged_at")

  latitude         Decimal?         @db.Decimal(10, 8)
  longitude        Decimal?         @db.Decimal(11, 8)

  /// Human-readable location resolved from lat/lng via geofence pool match.
  /// Null for biometric-source events where geofencing is not applicable.
  resolvedLocation String?          @map("resolved_location")

  /// True if coordinates matched an entry in the allowed locations pool.
  /// False triggers anti-fraud-scan BullMQ job dispatch. Null for biometric.
  geofenceMatched  Boolean?         @map("geofence_matched")

  /// JSONB: { deviceInfo: { deviceId, deviceType, osVersion, appVersion },
  ///          ipAddress, antiFraudFlags: string[] }
  /// Written once by the clock-event pipeline; never mutated.
  payload          Json?            @db.JsonB

  createdAt        DateTime         @default(now()) @map("created_at")

  @@index([dailyId])
  @@index([userId, loggedAt])
  @@map("attendance_logs")
}

// Per-employee per-year leave balance per category.
// entitled + carried - used - pending = remaining (computed in service layer).
// Policy config (gender constraints, document requirements, half-day rules)
// lives in payload JSONB to avoid adding a column per policy knob.
model LeaveBalance {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  year      Int
  leaveType LeaveType @map("leave_type")
  entitled  Decimal   @db.Decimal(5, 1)
  used      Decimal   @db.Decimal(5, 1)
  pending   Decimal   @db.Decimal(5, 1)
  carried   Decimal   @db.Decimal(5, 1)

  // JSONB: { expiryDate, color, allowHalfDay, requiresDocument, documentTypes,
  //          genderConstraint, maxConsecutiveDays, minAdvanceDays }
  payload   Json?     @db.JsonB

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt      @map("updated_at")

  @@unique([userId, year, leaveType])
  @@index([userId, year])
  @@map("leave_balances")
}

// Countrywide and regional public holidays. Used by getDayStatus and
// GetDataForLeavePattern to populate blackout date arrays.
model PublicHoliday {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date        DateTime @db.Date
  name        String
  countryCode String   @map("country_code")
  regionCode  String?  @map("region_code")
  isOptional  Boolean  @default(false) @map("is_optional")

  payload     Json?    @db.JsonB

  @@unique([date, countryCode])
  @@index([date])
  @@map("public_holidays")
}

// =============================================================================
// LEAVE REQUEST — XState-Managed Lifecycle
//
// The `status` column persists the XState state node name mapped via STATE_TO_STATUS.
// The `payload` JSONB column stores the full XState context snapshot:
//   { _v, _stateValue, approvalChain[], currentStepIndex, transitions[], ... }
//
// Deletion contract:
//   user → onDelete: Cascade
//     A leave request is owned data — it has no meaning without its requester.
//     Hard-deleting a User purges all their leave requests. This cascade
//     propagates further: LeaveRequest → LeaveApproval (Cascade),
//     producing a two-level clean sweep with zero audit orphans.
// =============================================================================

model LeaveRequest {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId      String             @map("user_id") @db.Uuid

  /// onDelete: Cascade — the leave request is owned by its requester.
  /// On GDPR hard-delete of a User, all their leave requests (and their
  /// LeaveApproval audit rows) are purged atomically.
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  leaveType   LeaveType          @map("leave_type")
  startDate   DateTime           @map("start_date") @db.Date
  endDate     DateTime           @map("end_date")   @db.Date

  /// Supports half-day values (e.g. 0.5). Decimal(5,1) allows up to 9999.9 days.
  totalDays   Decimal            @map("total_days") @db.Decimal(5, 1)
  reason      String
  status      LeaveRequestStatus @default(DRAFT)

  /// XState context snapshot + dynamic form fields (doctor certificate URL, etc.).
  /// Stores: _v, _stateValue, approvalChain[], currentStepIndex, lastApproverId,
  ///         lastRemarks, transitions[{ actorId, event, fromState, toState, ... }]
  /// ⚠ GIN index on this column is hand-authored in:
  ///     prisma/migrations/20260522235959_gin_indexes/migration.sql
  payload     Json?              @db.JsonB

  submittedAt DateTime?          @map("submitted_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt      @map("updated_at")

  /// Approval audit trail. Cascade-deleted when this leave request is deleted.
  approvals   LeaveApproval[]

  @@index([userId])
  @@index([status])

  /// Composite: "employee X's pending/active requests" — most common employee
  /// dashboard query and XState rehydration pre-check. Eliminates a full
  /// userId scan before the status filter is applied.
  @@index([userId, status])

  /// Composite: date-range overlap queries for leave calendar and conflict
  /// detection (e.g. "does this new request overlap an existing approved one?").
  @@index([startDate, endDate])

  @@map("leave_requests")
}

// =============================================================================
// LEAVE APPROVAL — Immutable Approval Audit Trail
//
// One row per decision event (APPROVE / REJECT / CANCEL) per leave request.
// Written atomically inside the same Prisma $transaction as the status update
// in LeaveRequestService.transition().
//
// Deletion contract:
//   leaveRequest → onDelete: Cascade
//     Approval steps are subordinate to their parent request. When a
//     LeaveRequest is deleted (directly or via User cascade), all its approval
//     rows are purged atomically. No orphaned audit rows.
//
//   approver → onDelete: Restrict
//     The approver's identity is part of the immutable audit record.
//     A User who has issued formal approval decisions cannot be hard-deleted
//     while these records exist. Use User.deletedAt for departing approvers.
//     If a GDPR hard-delete is legally required, anonymise the approverId
//     field before issuing the DELETE on the User row.
// =============================================================================

model LeaveApproval {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  leaveRequestId String       @map("leave_request_id") @db.Uuid

  /// onDelete: Cascade — approval rows are children of the leave request.
  /// Purged automatically when the parent request is deleted (including via
  /// the User → LeaveRequest → LeaveApproval two-level cascade chain).
  leaveRequest   LeaveRequest @relation(fields: [leaveRequestId], references: [id], onDelete: Cascade)

  approverId     String       @map("approver_id") @db.Uuid

  /// onDelete: Restrict — the approver is an accountable party in the audit trail.
  /// Hard-deleting an approver User while approval records reference them is blocked.
  /// Use User.deletedAt for normal departure flows.
  approver       User         @relation(fields: [approverId], references: [id], onDelete: Restrict)

  /// XState event type string. Values: "APPROVE" | "REJECT" | "CANCEL"
  action         String

  /// Required for REJECT actions; optional for APPROVE / CANCEL.
  /// Validated by the XState `hasRemarks` guard before the machine transitions.
  remarks        String?

  decidedAt      DateTime     @default(now()) @map("decided_at")

  /// Immutable snapshot of the full XState event payload that triggered this step.
  /// Enables post-hoc audit reconstruction of the exact machine input.
  /// ⚠ GIN index on this column is hand-authored in:
  ///     prisma/migrations/20260522235959_gin_indexes/migration.sql
  eventSnapshot  Json?        @map("event_snapshot") @db.JsonB

  /// Foreign key index — accelerates cascade DELETE and approval-for-request lookups.
  @@index([leaveRequestId])

  /// Enables "show all requests I have approved or rejected" — approver inbox.
  /// Previously missing — added in P0 block.
  @@index([approverId])

  @@map("leave_approvals")
}

// =============================================================================
// P1 — CORE HR FRAMEWORK
// JobPosition, GradeLevel, EmploymentContract, EmployeeMutation
// =============================================================================

// =============================================================================
// JOB POSITION — Formal Organisational Role Definition
//
// A JobPosition names the role a seat plays in the org chart (e.g. "Senior
// Software Engineer", "Regional Sales Manager"). It is subsidiary-scoped so
// each legal entity can maintain its own role catalogue independently.
//
// Deletion contract:
//   subsidiary → onDelete: Restrict — cannot delete a Subsidiary while it owns
//                active positions. Archive positions first (isActive = false).
//   unit       → onDelete: SetNull — unit restructuring must not delete historic
//                position records; unitId is cleared instead.
// =============================================================================

model JobPosition {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  /// Immutable short code. Stored in EmployeeMutation snapshots and CASL rules.
  /// Examples: "SE_SNR", "MGR_REG_SALES", "DIR_HC"
  code         String     @unique

  title        String

  subsidiaryId String     @map("subsidiary_id") @db.Uuid
  subsidiary   Subsidiary @relation(fields: [subsidiaryId], references: [id], onDelete: Restrict)

  /// Nullable — group-level positions may span multiple units; newly-defined
  /// positions may not yet be placed in the org chart.
  unitId       String?    @map("unit_id") @db.Uuid
  unit         Unit?      @relation(fields: [unitId], references: [id], onDelete: SetNull)

  isActive     Boolean    @default(true) @map("is_active")

  /// JSONB: { responsibilities[], competencyFramework, jobFamily, bandLevel,
  ///          minGradeLevelCode, maxGradeLevelCode }
  payload      Json?      @db.JsonB

  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt      @map("updated_at")

  // ---------------------------------------------------------------------------
  // BACK-REFERENCES
  // ---------------------------------------------------------------------------

  /// All employees currently holding this position.
  users                  User[]

  /// Contracts that explicitly enumerate this position.
  contracts              EmploymentContract[]

  /// Mutation audit rows where this was the employee's prior position.
  mutationsAsOldPosition EmployeeMutation[] @relation("MutationOldJobPosition")

  /// Mutation audit rows where this is the employee's new position.
  mutationsAsNewPosition EmployeeMutation[] @relation("MutationNewJobPosition")

  @@index([subsidiaryId])
  @@index([unitId])

  @@map("job_positions")
}

// =============================================================================
// GRADE LEVEL — Compensation Band / Career Tier
//
// Subsidiary-scoped compensation grade (e.g. G1…G7, M1…M3, D1…D2).
// Each grade carries an optional salary band and a sortable tier for ladder
// comparisons. Policy details (allowance structure, overtime rate) live in
// the payload JSONB column to avoid column proliferation.
//
// Deletion contract:
//   subsidiary → onDelete: Restrict — cannot delete a Subsidiary while it owns
//                active grades. Archive or reassign employees before removal.
// =============================================================================

model GradeLevel {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  subsidiaryId  String     @map("subsidiary_id") @db.Uuid
  subsidiary    Subsidiary @relation(fields: [subsidiaryId], references: [id], onDelete: Restrict)

  /// Short code unique within the subsidiary. Examples: "G1", "M2", "D3".
  code          String

  name          String

  /// Sortable numeric rank for ladder comparisons (lower = junior).
  tier          Int

  salaryBandMin Decimal?   @map("salary_band_min") @db.Decimal(15, 2)
  salaryBandMax Decimal?   @map("salary_band_max") @db.Decimal(15, 2)

  /// JSONB: { allowanceStructure, benefitTiers, overtimeRate, thr }
  payload       Json?      @db.JsonB

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt      @map("updated_at")

  // ---------------------------------------------------------------------------
  // BACK-REFERENCES
  // ---------------------------------------------------------------------------

  /// All employees currently at this grade level.
  users              User[]

  /// Contracts that explicitly enumerate this grade.
  contracts          EmploymentContract[]

  /// Mutation audit rows where this was the employee's prior grade.
  mutationsAsOldGrade EmployeeMutation[] @relation("MutationOldGradeLevel")

  /// Mutation audit rows where this is the employee's destination grade.
  mutationsAsNewGrade EmployeeMutation[] @relation("MutationNewGradeLevel")

  /// Grade codes are unique per subsidiary (e.g. both KPN_HO and KPN_LOG can
  /// have a "G1" grade with different salary bands).
  @@unique([subsidiaryId, code])

  /// Composite: "all grades for subsidiary X, sorted by tier" — grade-ladder
  /// API and promotion eligibility checks.
  @@index([subsidiaryId, tier])

  @@map("grade_levels")
}

// =============================================================================
// EMPLOYMENT CONTRACT — Legal Employment Agreement Record
//
// One row per employment contract issued to an employee. An employee may have
// multiple historical contracts (PKWT renewals, transition to PKWTT, etc.).
// The most recent ACTIVE contract is the authoritative one for payroll and
// compliance reporting.
//
// Contract type semantics (Indonesian manpower law):
//   PKWTT  — permanent employment; no endDate; automatically enforced.
//   PKWT   — fixed-term; endDate mandatory; max 5-year cumulative term.
//   INTERN — magang programme; endDate required; no statutory entitlements.
//   CONTRACT — outsourced or vendor-managed; managed by third party.
//
// Deletion contract:
//   user       → onDelete: Cascade — contract is owned employee data.
//   subsidiary → onDelete: Restrict — cannot delete a Subsidiary with contracts.
//   jobPosition → onDelete: SetNull — position restructuring must not block
//                  contract history; jobPositionId is cleared instead.
//   gradeLevel  → onDelete: SetNull — same rationale as jobPosition.
// =============================================================================

model EmploymentContract {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId         String         @map("user_id") @db.Uuid
  /// onDelete: Cascade — contract data is owned by its employee record.
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  subsidiaryId   String         @map("subsidiary_id") @db.Uuid
  /// onDelete: Restrict — cannot delete a Subsidiary while contracts are active.
  subsidiary     Subsidiary     @relation(fields: [subsidiaryId], references: [id], onDelete: Restrict)

  /// Official document number. Nullable for legacy backfill where numbers are
  /// not yet digitised. Unique once set — prevents duplicate contract entry.
  contractNumber String?        @unique @map("contract_number")

  contractType   ContractType   @map("contract_type")
  contractStatus ContractStatus @default(ACTIVE) @map("contract_status")

  startDate      DateTime       @map("start_date") @db.Date

  /// Null for PKWTT (open-ended permanent). Mandatory for PKWT, INTERN, CONTRACT.
  /// Validated at the service layer, not at the DB level.
  endDate        DateTime?      @map("end_date") @db.Date

  jobPositionId  String?        @map("job_position_id") @db.Uuid
  /// onDelete: SetNull — position restructuring must not corrupt contract history.
  jobPosition    JobPosition?   @relation(fields: [jobPositionId], references: [id], onDelete: SetNull)

  gradeLevelId   String?        @map("grade_level_id") @db.Uuid
  /// onDelete: SetNull — grade restructuring must not corrupt contract history.
  gradeLevel     GradeLevel?    @relation(fields: [gradeLevelId], references: [id], onDelete: SetNull)

  signedAt       DateTime?      @map("signed_at")

  /// JSONB: { documentUrl, signingParties[], renewalHistory[], specialClauses,
  ///          pkwtExtensionCount, probationEndDate, insuranceNumber }
  payload        Json?          @db.JsonB

  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt      @map("updated_at")

  @@index([userId])

  /// Composite: "show all ACTIVE contracts for subsidiary X" — payroll cycle and
  /// compliance headcount. Subset of the full-table scan on subsidiaryId alone.
  @@index([subsidiaryId, contractStatus])

  /// Composite: "all contracts for employee X, filtered by status" — employee
  /// profile card and contract renewal reminder jobs.
  @@index([userId, contractStatus])

  @@map("employment_contracts")
}

// =============================================================================
// EMPLOYEE MUTATION — Immutable Career Movement Audit Trail
//
// One row per career event (promotion, demotion, lateral mutation, cross-entity
// transfer). Written atomically alongside the User record update that reflects
// the movement. Never mutated after creation (soft-cancel via mutationStatus).
//
// Snapshot design:
//   All 8 old*/new* FK pairs capture the employee's state at the moment of the
//   event. They use onDelete: SetNull so that subsequent restructuring of master
//   data (removing a position, merging units, disbanding a subsidiary) does not
//   retroactively destroy the audit trail — the snapshot fields are simply
//   nulled while the record itself is preserved.
//
// TRANSFER_PT semantics:
//   When mutationType = TRANSFER_PT, newSubsidiaryId ≠ oldSubsidiaryId.
//   The service layer MUST issue a new EmploymentContract under the destination
//   Subsidiary immediately after recording this mutation. The mutation record
//   should carry the skNumber of the transfer decree.
//
// Deletion contract:
//   user       → onDelete: Cascade ("MutationEmployee") — career history is
//                owned data; purged with the user on GDPR hard-delete.
//   approvedBy → onDelete: SetNull ("MutationApprover") — hard-deleting the
//                approving officer clears the reference; record is preserved.
//   All snapshot FKs → onDelete: SetNull (see Snapshot design above).
// =============================================================================

model EmployeeMutation {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId         String         @map("user_id") @db.Uuid
  user           User           @relation("MutationEmployee", fields: [userId], references: [id], onDelete: Cascade)

  mutationType   MutationType   @map("mutation_type")
  mutationStatus MutationStatus @default(PENDING) @map("mutation_status")
  effectiveDate  DateTime       @map("effective_date") @db.Date

  /// Official HR decree number (Nomor SK). Mandatory for TRANSFER_PT mutations.
  skNumber       String?        @map("sk_number")

  // ---------------------------------------------------------------------------
  // SNAPSHOT — Before State (old*)
  // ---------------------------------------------------------------------------

  oldSubsidiaryId  String?     @map("old_subsidiary_id")   @db.Uuid
  oldSubsidiary    Subsidiary? @relation("MutationOldSubsidiary", fields: [oldSubsidiaryId], references: [id], onDelete: SetNull)

  oldUnitId        String?     @map("old_unit_id")         @db.Uuid
  oldUnit          Unit?       @relation("MutationOldUnit", fields: [oldUnitId], references: [id], onDelete: SetNull)

  oldJobPositionId String?     @map("old_job_position_id") @db.Uuid
  oldJobPosition   JobPosition? @relation("MutationOldJobPosition", fields: [oldJobPositionId], references: [id], onDelete: SetNull)

  oldGradeLevelId  String?     @map("old_grade_level_id")  @db.Uuid
  oldGradeLevel    GradeLevel? @relation("MutationOldGradeLevel", fields: [oldGradeLevelId], references: [id], onDelete: SetNull)

  // ---------------------------------------------------------------------------
  // SNAPSHOT — After State (new*)
  // ---------------------------------------------------------------------------

  newSubsidiaryId  String?     @map("new_subsidiary_id")   @db.Uuid
  newSubsidiary    Subsidiary? @relation("MutationNewSubsidiary", fields: [newSubsidiaryId], references: [id], onDelete: SetNull)

  newUnitId        String?     @map("new_unit_id")         @db.Uuid
  newUnit          Unit?       @relation("MutationNewUnit", fields: [newUnitId], references: [id], onDelete: SetNull)

  newJobPositionId String?     @map("new_job_position_id") @db.Uuid
  newJobPosition   JobPosition? @relation("MutationNewJobPosition", fields: [newJobPositionId], references: [id], onDelete: SetNull)

  newGradeLevelId  String?     @map("new_grade_level_id")  @db.Uuid
  newGradeLevel    GradeLevel? @relation("MutationNewGradeLevel", fields: [newGradeLevelId], references: [id], onDelete: SetNull)

  // ---------------------------------------------------------------------------
  // APPROVER — HR Officer or Manager
  // ---------------------------------------------------------------------------

  approvedById   String?        @map("approved_by_id") @db.Uuid
  approvedBy     User?          @relation("MutationApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  /// JSONB: { reason, skDocumentUrl, effectivePayslipCycle, notes, notifiedAt }
  payload        Json?          @db.JsonB

  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt      @map("updated_at")

  /// Composite: "all career events for employee X, pending or approved" —
  /// employee timeline view and mutation approval queue.
  @@index([userId, mutationStatus])

  /// Single-column index on effectiveDate — used by payroll cycle job to find
  /// all mutations effective within the current billing period.
  @@index([effectiveDate])

  @@map("employee_mutations")
}

// =============================================================================
// P2 — PAYROLL & WORKFLOW ENGINE
// PayrollPeriod, Payslip, PayslipLine, WorkflowDefinition, WorkflowInstance
// =============================================================================

// =============================================================================
// PAYROLL PERIOD — Siklus Periode Penggajian
//
// The canonical unit of a payroll run. Every payslip belongs to exactly one
// PayrollPeriod — the period defines the date window, the status gate, and the
// tenant boundary for the entire disbursement cycle.
//
// Lifecycle transitions (one-directional):
//   OPEN → PROCESSING → CLOSED → ARCHIVED
//
// State rules enforced by the service layer (not at DB level):
//   • Only OPEN periods accept new Payslip drafts or amendments.
//   • Transition to PROCESSING locks all payslips for editing and enqueues
//     the BullMQ `payroll-engine` job.
//   • Transition to CLOSED triggers the disbursement pipeline and sends
//     payslip PDFs to employee inboxes.
//   • ARCHIVED periods are immutable and retained for statutory audit.
//
// Deletion contract:
//   subsidiary → onDelete: Restrict — cannot delete a Subsidiary while payroll
//                periods exist under it. Statutory retention requires preservation.
// =============================================================================

model PayrollPeriod {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  subsidiaryId String              @map("subsidiary_id") @db.Uuid

  /// onDelete: Restrict — a Subsidiary cannot be hard-deleted while payroll
  /// periods are registered under it. Statutory compliance requires retention.
  subsidiary   Subsidiary          @relation(fields: [subsidiaryId], references: [id], onDelete: Restrict)

  /// Immutable machine-readable period code. Unique per subsidiary.
  /// Convention: "PAY-{YYYY}-{MM}" — e.g. "PAY-2026-05".
  /// Set once at creation; referenced in payslip document headers and bank
  /// transfer batch files.
  code         String

  /// Human-readable period label shown on payslip PDFs and HR dashboards.
  /// Examples: "Periode Gaji Mei 2026", "Periode Gaji THR Lebaran 2026"
  name         String

  /// First calendar day of the pay window (inclusive). Stored as a date-only
  /// value — no time component. Covers the earnings computation window.
  startDate    DateTime            @map("start_date") @db.Date

  /// Last calendar day of the pay window (inclusive). endDate >= startDate
  /// enforced by the service layer.
  endDate      DateTime            @map("end_date") @db.Date

  status       PayrollPeriodStatus @default(OPEN)

  /// JSONB: { approvedById, approvedAt, disbursementRef, bankBatchFileUrl,
  ///          closedAt, archivedAt, payrollEngineJobId }
  payload      Json?               @db.JsonB

  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt      @map("updated_at")

  // ---------------------------------------------------------------------------
  // BACK-REFERENCES
  // ---------------------------------------------------------------------------

  /// All payslips generated for employees within this period.
  /// onDelete: Restrict declared on Payslip — a period cannot be hard-deleted
  /// while its payslips still exist. Archive the period instead.
  payslips     Payslip[]

  // ---------------------------------------------------------------------------
  // INDEXES
  // ---------------------------------------------------------------------------

  /// Unique constraint — one period code per legal entity.
  /// Prevents duplicate "PAY-2026-05" entries across subsidiaries that each
  /// maintain their own independent payroll calendars.
  @@unique([subsidiaryId, code])

  /// Range index — covers date-overlap queries used by the payroll engine to
  /// detect whether a mutation's effectiveDate falls within an open period.
  @@index([startDate, endDate])

  /// Composite: "all OPEN periods for subsidiary X" — payroll dashboard and
  /// BullMQ job scheduler pre-check.
  @@index([subsidiaryId, status])

  @@map("payroll_periods")
}

// =============================================================================
// PAYSLIP — Master Slip Gaji Karyawan
//
// One row per employee per payroll period. This is the aggregate header that
// carries the financial totals. The itemised breakdown lives in PayslipLine.
// The unique constraint on [payrollPeriodId, userId] is the hard guard against
// accidental double-payslip generation for the same employee in one cycle.
//
// Deletion contract (all Restrict — payslips are statutory financial records):
//   user         → onDelete: Restrict — a User with issued payslips cannot be
//                  hard-deleted. Use soft-delete (deletedAt) for departed staff;
//                  payslips must survive the employee record for audit purposes.
//   payrollPeriod → onDelete: Restrict — cannot delete a PayrollPeriod while
//                  payslips exist under it. Close/archive the period instead.
//   subsidiary   → onDelete: Restrict — same rationale as payrollPeriod.
// =============================================================================

model Payslip {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId          String        @map("user_id") @db.Uuid

  /// onDelete: Restrict — statutory financial records must outlive the employee
  /// row. Hard delete of a User is blocked if any payslip references them.
  user            User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  payrollPeriodId String        @map("payroll_period_id") @db.Uuid

  /// onDelete: Restrict — payslips are subordinate to but must survive their
  /// period for compliance. Archive the period; do not hard-delete it.
  payrollPeriod   PayrollPeriod @relation(fields: [payrollPeriodId], references: [id], onDelete: Restrict)

  subsidiaryId    String        @map("subsidiary_id") @db.Uuid

  /// Denormalised tenant anchor. Equals user.subsidiaryId and
  /// payrollPeriod.subsidiaryId — enforced by the payroll-engine service.
  /// Enables O(1) tenant-scoped payslip queries without double JOIN.
  /// onDelete: Restrict — same statutory rationale.
  subsidiary      Subsidiary    @relation(fields: [subsidiaryId], references: [id], onDelete: Restrict)

  // ---------------------------------------------------------------------------
  // FINANCIAL TOTALS — Decimal(15, 2) for monetary precision
  // All amounts are stored in IDR (Indonesian Rupiah), no currency column
  // required unless multi-currency support is added in a future migration.
  // ---------------------------------------------------------------------------

  /// Sum of all EARNING lines with code prefix "BASIC_*".
  totalBasic      Decimal       @map("total_basic")     @db.Decimal(15, 2)

  /// Sum of all EARNING lines with code prefix "ALLOW_*".
  totalAllowance  Decimal       @map("total_allowance") @db.Decimal(15, 2)

  /// Sum of all DEDUCTION lines. Stored as a positive number; subtracted in THP
  /// computation: takeHomePay = (totalBasic + totalAllowance) − totalDeduction.
  totalDeduction  Decimal       @map("total_deduction") @db.Decimal(15, 2)

  /// Net take-home pay after all deductions. Equals:
  ///   totalBasic + totalAllowance − totalDeduction
  /// Pre-computed and stored here for reporting performance — avoids
  /// SUM(lines) at query time on every dashboard load.
  takeHomePay     Decimal       @map("take_home_pay")   @db.Decimal(15, 2)

  status          PayslipStatus @default(DRAFT)

  /// JSONB: { bankAccountNumber, bankName, bankBranchCode, disbursementRef,
  ///          approvedById, approvedAt, paidAt, payslipPdfUrl,
  ///          pph21Amount, bpjsKesAmount, bpjsTkAmount }
  payload         Json?         @db.JsonB

  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt      @map("updated_at")

  // ---------------------------------------------------------------------------
  // BACK-REFERENCES
  // ---------------------------------------------------------------------------

  /// All itemised line components composing this payslip.
  /// Cascade-deleted when this master payslip row is deleted.
  lines           PayslipLine[]

  // ---------------------------------------------------------------------------
  // INDEXES
  // ---------------------------------------------------------------------------

  /// Hard uniqueness constraint — one payslip per employee per period.
  /// Prevents the payroll engine from accidentally double-submitting a run
  /// for the same [period, user] pair.
  @@unique([payrollPeriodId, userId])

  /// Composite: "all DRAFT payslips for subsidiary X" — payroll approval
  /// queue and BullMQ job batch status dashboard.
  @@index([subsidiaryId, status])

  /// Single-column index on userId — employee payslip history lookup.
  @@index([userId])

  @@map("payslips")
}

// =============================================================================
// PAYSLIP LINE — Detail Komponen Slip Gaji
//
// One row per earnings or deduction component within a payslip. Examples:
//   EARNING  : Gaji Pokok, Tunjangan Jabatan, Tunjangan Makan, Lembur
//   DEDUCTION: Potongan Absensi, Cicilan Koperasi, BPJS Ketenagakerjaan, PPh21
//
// Lines are append-only during DRAFT status and immutable once the parent
// payslip transitions to APPROVED. The service layer enforces this invariant.
//
// Deletion contract:
//   payslip → onDelete: Cascade — line items are owned by their master payslip.
//             Deleting the master record (e.g. during payroll engine rollback
//             in DRAFT status) atomically purges all associated lines.
// =============================================================================

model PayslipLine {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  payslipId String          @map("payslip_id") @db.Uuid

  /// onDelete: Cascade — line items are subordinate to their master payslip.
  /// Atomic purge of lines happens automatically on payslip deletion (e.g.
  /// engine rollback of a DRAFT payslip during period re-processing).
  payslip   Payslip         @relation(fields: [payslipId], references: [id], onDelete: Cascade)

  /// Machine-readable component code. Used by the payroll engine to identify
  /// the calculation rule, map to statutory reporting buckets, and deduplicate
  /// components across re-generation runs.
  /// Naming convention by prefix:
  ///   BASIC_*   → base salary components  (e.g. BASIC_SALARY)
  ///   ALLOW_*   → allowance components    (e.g. ALLOW_TRANSPORT, ALLOW_MEAL)
  ///   DEDUCT_*  → deduction components   (e.g. DEDUCT_ABSENCE, DEDUCT_LOAN)
  ///   TAX_*     → statutory tax items    (e.g. TAX_PPH21)
  ///   INS_*     → insurance contributions (e.g. INS_BPJS_KES, INS_BPJS_TK)
  code      String

  /// Human-readable component label printed on the payslip PDF.
  /// Examples: "Gaji Pokok", "Tunjangan Transportasi", "Potongan Keterlambatan"
  name      String

  type      PayslipLineType

  /// Component amount in IDR. Always stored as a positive value regardless of
  /// type — the DEDUCTION sign is applied by the THP computation, not here.
  amount    Decimal         @db.Decimal(15, 2)

  /// Optional explanatory note for non-standard or one-off components.
  /// Examples: "Lembur 8 jam @ Rp 85.000", "Potongan cicilan bulan ke-3/12"
  note      String?

  createdAt DateTime        @default(now()) @map("created_at")

  // ---------------------------------------------------------------------------
  // INDEXES
  // ---------------------------------------------------------------------------

  /// Composite: "all DEDUCTION lines for payslip X" — payslip detail page and
  /// statutory deduction reporting (PPh21 recap, BPJS contribution summary).
  @@index([payslipId, type])

  @@map("payslip_lines")
}

// =============================================================================
// WORKFLOW DEFINITION — Konfigurasi Alur Kerja Generik (Blueprint)
//
// The immutable blueprint for an approval chain. Each WorkflowDefinition stores
// the canonical XState machine configuration (steps, states, transition rules,
// actor assignment logic) for a specific module and subsidiary combination.
//
// One WorkflowDefinition can spawn many WorkflowInstance records — one per
// domain entity that enters the approval process (one leave request, one
// mutation, one payslip approval ticket, etc.).
//
// Integration pattern with XState:
//   The `config` JSONB column stores the full machine descriptor:
//   { initialState, states[], transitions[], stepActors[], guardRules[] }
//   The leave-request machine is pre-wired; other modules use this table to
//   support configurable multi-step chains without schema migrations.
//
// Deletion contract:
//   subsidiary → onDelete: Restrict — cannot delete a Subsidiary while workflow
//                blueprints are registered under it.
// =============================================================================

model WorkflowDefinition {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id           String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  subsidiaryId String             @map("subsidiary_id") @db.Uuid

  /// onDelete: Restrict — cannot delete a Subsidiary while approval blueprints
  /// are registered under it. Deactivate (isActive = false) instead.
  subsidiary   Subsidiary         @relation(fields: [subsidiaryId], references: [id], onDelete: Restrict)

  /// Immutable machine-readable code. Unique per subsidiary.
  /// Convention: "WF_{MODULE}_{VARIANT}" — e.g. "WF_LEAVE_REQ",
  /// "WF_MUTATION_TRANSFER", "WF_PAYSLIP_APPROVAL".
  code         String

  /// Human-readable name displayed in the admin workflow configurator.
  /// Examples: "Alur Persetujuan Cuti", "Alur Mutasi Lintas Entitas"
  name         String

  /// Domain module this blueprint belongs to. Used by the Task Box router to
  /// resolve the correct XState machine factory and service handler.
  module       WorkflowModule

  /// Full XState machine descriptor stored as structured JSON.
  /// Schema (enforced by the workflow-config service, not at DB level):
  /// {
  ///   version: number,
  ///   initialState: string,
  ///   states: { [stateName]: { on: { [event]: targetState } } }[],
  ///   steps: [{
  ///     stepIndex: number,
  ///     label: string,
  ///     actorResolutionStrategy: "DIRECT_USER" | "POSITION_ROLE" | "UNIT_MANAGER",
  ///     actorPositionCodes: string[],
  ///     fallbackActorId: string | null
  ///   }][],
  ///   guards: { [guardName]: GuardDescriptor }
  /// }
  config       Json               @db.JsonB

  /// Soft-deactivation flag. Inactive definitions reject new instance creation
  /// but existing RUNNING instances continue until completion.
  isActive     Boolean            @default(true) @map("is_active")

  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt      @map("updated_at")

  // ---------------------------------------------------------------------------
  // BACK-REFERENCES
  // ---------------------------------------------------------------------------

  /// All live and historical approval tickets spawned from this blueprint.
  /// onDelete: Restrict declared on WorkflowInstance — cannot delete a definition
  /// while active instances reference it.
  instances    WorkflowInstance[]

  // ---------------------------------------------------------------------------
  // INDEXES
  // ---------------------------------------------------------------------------

  /// Unique constraint — one definition code per legal entity.
  @@unique([subsidiaryId, code])

  @@map("workflow_definitions")
}

// =============================================================================
// WORKFLOW INSTANCE — Transaksi Alur Kerja Aktif (Task Box Ticket)
//
// One row per live approval ticket in the Task Box. Created when a domain
// entity (LeaveRequest, EmployeeMutation, Payslip, etc.) enters the approval
// pipeline. Stores the full live XState context snapshot for the running actor.
//
// Polymorphic entity reference design:
//   entityId is a plain UUID string (not a typed FK) pointing to the owning
//   domain record. This intentional design choice avoids a combinatorial
//   explosion of FK columns for each supported entity type and allows the
//   workflow engine to support new modules without schema migrations.
//   The service layer is responsible for validating entityId against the correct
//   table based on WorkflowDefinition.module.
//
// XState integration:
//   context JSONB = full XState snapshot stored between action dispatches.
//   On each Task Box action (APPROVE / REJECT / CANCEL), the service:
//     1. Loads the WorkflowInstance row and rehydrates the actor from context.
//     2. Sends the event via the ephemeral actor pattern.
//     3. Writes the new context snapshot back atomically.
//     4. Updates the linked entity's status field in the same transaction.
//
// Deletion contract:
//   definition → onDelete: Restrict — instances depend on their blueprint.
//   subsidiary → onDelete: Restrict — cannot delete a Subsidiary with active
//                approval tickets. Terminate instances first.
// =============================================================================

model WorkflowInstance {
  /// Primary key — UUID generated by PostgreSQL pgcrypto extension.
  id           String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  definitionId String                 @map("definition_id") @db.Uuid

  /// onDelete: Restrict — an instance depends on its blueprint for state
  /// resolution. Cannot delete a WorkflowDefinition with active instances.
  definition   WorkflowDefinition     @relation(fields: [definitionId], references: [id], onDelete: Restrict)

  subsidiaryId String                 @map("subsidiary_id") @db.Uuid

  /// Denormalised tenant anchor. Must equal definition.subsidiaryId — enforced
  /// by the workflow-engine service at instance creation time.
  /// onDelete: Restrict — cannot delete a Subsidiary with running tickets.
  subsidiary   Subsidiary             @relation(fields: [subsidiaryId], references: [id], onDelete: Restrict)

  /// Polymorphic reference to the owning domain entity UUID.
  /// Resolved against the domain table indicated by definition.module:
  ///   LEAVE      → leave_requests.id
  ///   ATTENDANCE → attendance_daily.id
  ///   MUTATION   → employee_mutations.id
  ///   PAYROLL    → payslips.id
  /// Not a typed FK — cross-model polymorphism is handled by the service layer.
  entityId     String                 @map("entity_id") @db.Uuid

  /// Current XState state node name for the running instance.
  /// Examples: "WAITING_FOR_SUPERVISOR", "WAITING_FOR_L2", "APPROVED"
  /// Written on every transition; readable by the Task Box list API for
  /// rendering step indicators without deserialising the full context.
  currentState String                 @map("current_state")

  /// Full XState context snapshot — the live actor memory between dispatches.
  /// Schema mirrors LeaveRequest.payload.context:
  /// {
  ///   _v: number,
  ///   _stateValue: string,
  ///   approvalChain: ApprovalChainStep[],
  ///   currentStepIndex: number,
  ///   lastApproverId: string | null,
  ///   lastRemarks: string | null,
  ///   transitions: TransitionAuditEntry[]
  /// }
  context      Json                   @db.JsonB

  status       WorkflowInstanceStatus @default(RUNNING)

  createdAt    DateTime               @default(now()) @map("created_at")
  updatedAt    DateTime               @updatedAt      @map("updated_at")

  // ---------------------------------------------------------------------------
  // INDEXES
  // ---------------------------------------------------------------------------

  /// Composite: [definitionId, entityId] — "find the active ticket for this
  /// specific entity" — the hottest query in the Task Box service.
  /// Used on every APPROVE / REJECT action to load the correct instance.
  @@index([definitionId, entityId])

  /// Composite: "all RUNNING tickets in subsidiary X" — Task Box list API and
  /// SLA-breach monitoring job. Eliminates a full table scan on every load.
  @@index([subsidiaryId, status])

  @@map("workflow_instances")
}
